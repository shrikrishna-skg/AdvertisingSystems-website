---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import { featureSubpageFaqs } from '../../data/page-faqs';

const painPoints = [
  {
    icon: 'M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0112 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125M13.125 12h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125M20.625 12c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5M12 14.625v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 14.625c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125m0 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 13.125c0-.621.504-1.125 1.125-1.125h7.5',
    title: 'Spreadsheet Reporting Nightmares',
    desc: 'Hours spent pulling CSV exports from five platforms, manually merging data, and building pivot tables — only to have them outdated by the time you present.',
  },
  {
    icon: 'M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z',
    title: 'Attribution Black Box',
    desc: 'Which channel actually drove the sale? Platform-reported conversions overlap, double-count, and contradict each other. True ROI remains a mystery.',
  },
  {
    icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
    title: 'Missed Anomalies',
    desc: 'A campaign\'s CPC spikes 300% overnight but nobody notices until the weekly review. Thousands wasted on problems that could have been caught in minutes.',
  },
];

const capabilities = [
  {
    icon: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Revenue Attribution',
    desc: 'Cross-channel attribution that de-duplicates conversions and shows which touchpoints actually drove revenue — not platform-inflated numbers.',
  },
  {
    icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
    title: 'Live Dashboards',
    desc: 'Real-time performance data across every channel, campaign, and ad group. No more waiting for yesterday\'s numbers.',
  },
  {
    icon: 'M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0',
    title: 'Anomaly Alerts',
    desc: 'Instant notifications when metrics deviate from expected patterns. Catch CPC spikes, conversion drops, and budget pacing issues in real time.',
  },
  {
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
    title: 'Custom Reports',
    desc: 'Drag-and-drop report builder with white-label exports. Schedule automated delivery to stakeholders — PDFs, dashboards, or Slack.',
  },
];

const relatedFeatures = [
  { title: 'Campaign Intelligence', href: '/features/campaign-management', stat: '14 campaigns in 20min' },
  { title: 'AI Optimization Engine', href: '/features/ai-optimization', stat: '40% lower CPA' },
  { title: 'Automation Studio', href: '/features/automation', stat: '12hrs saved/week' },
  { title: 'Budget Allocator', href: '/features/budget-intelligence', stat: '5.2x ROAS' },
];
---

<Layout
  breadcrumbs={[{ name: 'Features', href: '/features' }, { name: 'Performance Analytics', href: '/features/analytics' }]}
  title="Performance Analytics — AdvertisingSystems | Cross-Channel Reporting & Attribution"
  description="From data to decisions in seconds. Real-time dashboards, cross-channel attribution, and anomaly alerts across every advertising platform."
>
  <Navbar />
  <Breadcrumb items={[{ name: 'Features', href: '/features' }, { name: 'Performance Analytics', href: '/features/analytics' }]} />
  <main>
    <!-- Hero -->
    <section class="relative pt-40 pb-20 sm:pt-48 sm:pb-28 overflow-hidden" aria-labelledby="analytics-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal inline-flex items-center gap-2 glass rounded-full px-5 py-2 mb-8">
          <span class="w-2 h-2 bg-[var(--text-muted)] rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-[var(--text-tertiary)]">$180K attributed revenue in one report</span>
        </div>

        <h1 id="analytics-heading" class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          <span class="text-[var(--text-primary)]">Performance Analytics</span>
        </h1>
        <p class="reveal mt-4 text-xl sm:text-2xl text-[var(--text-secondary)] font-medium">
          From data to decisions in seconds.
        </p>
        <p class="reveal mt-6 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          Real-time dashboards, cross-channel attribution, and anomaly alerts. See the full picture of your advertising performance without touching a spreadsheet.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg ">
            See It In Action
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Pain Points -->
    <section class="py-28" aria-labelledby="pain-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="pain-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Sound <span class="text-[var(--text-primary)]">familiar?</span>
          </h2>
          <p class="reveal mt-4 text-lg text-[var(--text-tertiary)] max-w-xl mx-auto">The reporting gaps that cost you time, money, and clarity.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {painPoints.map((point) => (
            <div class="reveal glass hover-glow rounded-2xl p-8 border-t-4 border-red-400/30">
              <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={point.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-2">{point.title}</h3>
              <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">{point.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- App Mockup -->
    <section class="py-28" aria-labelledby="mockup-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="mockup-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Your complete performance <span class="text-[var(--text-primary)]">picture.</span>
          </h2>
        </div>

        <div class="reveal glass rounded-2xl overflow-hidden shadow-2xl">
          <div class="flex items-center gap-2 px-5 py-3.5 border-b border-[var(--browser-border)] bg-[var(--browser-chrome-bg)]">
            <div class="flex gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
            </div>
            <div class="flex-1 ml-3">
              <div class="bg-[var(--browser-url-bg)] rounded-md px-3 py-1 text-xs text-[var(--browser-url-text)] max-w-xs">app.advertisingsystems.ai/analytics</div>
            </div>
          </div>
          <div class="p-6 sm:p-8 bg-[var(--surface-alt)]">
            <!-- KPI Cards -->
            <div class="grid grid-cols-4 gap-4 mb-6">
              <div class="glass rounded-lg p-4">
                <div class="text-xs text-[var(--text-muted)] mb-1">Total Revenue</div>
                <div class="text-2xl font-bold text-[var(--text-primary)]">$182,450</div>
                <div class="text-xs text-[var(--text-primary)] mt-1 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                  +24.3%
                </div>
              </div>
              <div class="glass rounded-lg p-4">
                <div class="text-xs text-[var(--text-muted)] mb-1">Total Spend</div>
                <div class="text-2xl font-bold text-[var(--text-primary)]">$34,820</div>
                <div class="text-xs text-[var(--text-primary)] mt-1 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 4.5l15 15m0 0V8.25m0 11.25H8.25" /></svg>
                  -8.1%
                </div>
              </div>
              <div class="glass rounded-lg p-4">
                <div class="text-xs text-[var(--text-muted)] mb-1">Blended ROAS</div>
                <div class="text-2xl font-bold text-[var(--text-primary)]">5.24x</div>
                <div class="text-xs text-[var(--text-primary)] mt-1 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                  +35.2%
                </div>
              </div>
              <div class="glass rounded-lg p-4">
                <div class="text-xs text-[var(--text-muted)] mb-1">Conversions</div>
                <div class="text-2xl font-bold text-[var(--text-primary)]">1,847</div>
                <div class="text-xs text-[var(--text-primary)] mt-1 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                  +18.7%
                </div>
              </div>
            </div>
            <!-- Chart Area -->
            <div class="glass rounded-lg p-5 mb-6">
              <div class="flex items-center justify-between mb-4">
                <div class="text-sm font-semibold text-[var(--text-primary)]">Revenue vs Spend (30 days)</div>
                <div class="flex items-center gap-4 text-xs text-[var(--text-muted)]">
                  <span class="flex items-center gap-1"><span class="w-2 h-2 bg-[var(--text-primary)] rounded-full"></span> Revenue</span>
                  <span class="flex items-center gap-1"><span class="w-2 h-2 bg-blue-500 rounded-full"></span> Spend</span>
                </div>
              </div>
              <div class="flex items-end gap-1 h-32">
                {[40, 52, 48, 61, 55, 70, 65, 78, 72, 85, 80, 92, 88, 95, 90].map((h) => (
                  <div class="flex-1 flex flex-col gap-0.5">
                    <div class="rounded-t bg-gradient-to-t from-[var(--text-tertiary)] to-[var(--text-muted)]" style={`height: ${h}%`}></div>
                    <div class="rounded-t bg-blue-500/40" style={`height: ${h * 0.2}%`}></div>
                  </div>
                ))}
              </div>
            </div>
            <!-- Attribution Table -->
            <div class="glass rounded-lg overflow-hidden">
              <div class="px-4 py-3 border-b border-[var(--border)]">
                <div class="text-sm font-semibold text-[var(--text-primary)]">Channel Attribution</div>
              </div>
              <div class="grid grid-cols-12 gap-2 px-4 py-2.5 border-b border-[var(--border)] text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">
                <div class="col-span-3">Channel</div>
                <div class="col-span-2 text-right">Spend</div>
                <div class="col-span-2 text-right">Revenue</div>
                <div class="col-span-2 text-right">ROAS</div>
                <div class="col-span-3">Share</div>
              </div>
              <div class="grid grid-cols-12 gap-2 px-4 py-3 border-b border-[var(--border)] text-sm items-center">
                <div class="col-span-3 font-medium text-[var(--text-primary)]">Google Ads</div>
                <div class="col-span-2 text-right text-[var(--text-tertiary)]">$14,200</div>
                <div class="col-span-2 text-right text-[var(--text-tertiary)]">$82,100</div>
                <div class="col-span-2 text-right font-medium text-[var(--text-primary)]">5.78x</div>
                <div class="col-span-3">
                  <div class="h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                    <div class="h-full rounded-full bg-gradient-to-r from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="width: 45%"></div>
                  </div>
                </div>
              </div>
              <div class="grid grid-cols-12 gap-2 px-4 py-3 border-b border-[var(--border)] text-sm items-center">
                <div class="col-span-3 font-medium text-[var(--text-primary)]">Meta Ads</div>
                <div class="col-span-2 text-right text-[var(--text-tertiary)]">$12,400</div>
                <div class="col-span-2 text-right text-[var(--text-tertiary)]">$64,350</div>
                <div class="col-span-2 text-right font-medium text-[var(--text-primary)]">5.19x</div>
                <div class="col-span-3">
                  <div class="h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                    <div class="h-full rounded-full bg-gradient-to-r from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="width: 35%"></div>
                  </div>
                </div>
              </div>
              <div class="grid grid-cols-12 gap-2 px-4 py-3 text-sm items-center">
                <div class="col-span-3 font-medium text-[var(--text-primary)]">Booking.com</div>
                <div class="col-span-2 text-right text-[var(--text-tertiary)]">$8,220</div>
                <div class="col-span-2 text-right text-[var(--text-tertiary)]">$36,000</div>
                <div class="col-span-2 text-right font-medium text-[var(--text-primary)]">4.38x</div>
                <div class="col-span-3">
                  <div class="h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                    <div class="h-full rounded-full bg-gradient-to-r from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="width: 20%"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Capabilities -->
    <section class="py-28" aria-labelledby="capabilities-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="capabilities-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Key <span class="text-[var(--text-primary)]">capabilities</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {capabilities.map((cap) => (
            <div class="reveal glass hover-glow rounded-2xl p-8">
              <div class="w-12 h-12 rounded-xl bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-[var(--text-tertiary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={cap.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-2">{cap.title}</h3>
              <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">{cap.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Testimonial -->
    <section class="py-28" aria-labelledby="testimonial-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal glass rounded-2xl p-10 sm:p-14">
          <svg class="w-10 h-10 text-[var(--text-primary)]/30 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
          </svg>
          <blockquote>
            <p id="testimonial-heading" class="text-xl sm:text-2xl font-medium text-[var(--text-primary)] leading-relaxed">
              "Our weekly reporting used to take a full day. Now I pull a cross-channel attribution report in 30 seconds that shows $180K in attributed revenue."
            </p>
          </blockquote>
          <div class="mt-8">
            <div class="font-semibold text-[var(--text-primary)]">James Okoro</div>
            <div class="text-sm text-[var(--text-muted)]">Director of Analytics, Pacific Coast Hotels</div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Related Features -->
    <section class="py-28" aria-labelledby="related-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="related-heading" class="reveal text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Explore more <span class="text-[var(--text-primary)]">features</span>
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relatedFeatures.map((feature) => (
            <a href={feature.href} class="reveal group glass hover-glow rounded-2xl p-6 transition-all duration-300 block">
              <h3 class="text-base font-bold text-[var(--text-primary)] mb-2 group-hover:text-[var(--text-tertiary)] transition-colors">{feature.title}</h3>
              <span class="text-xs font-semibold bg-[var(--surface-alt)] border border-[var(--border)] text-[var(--text-tertiary)] px-2.5 py-1 rounded-full">{feature.stat}</span>
              <div class="mt-4">
                <svg class="w-5 h-5 text-[var(--text-muted)] group-hover:text-[var(--text-primary)] group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={featureSubpageFaqs} name="analytics-faq" />

    <div class="section-line"></div>

    <!-- CTA -->
