---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { otaAdvertisingFaqs } from '../data/page-faqs';
import { otaPlatforms, otaPainPoints, otaCapabilities, otaStats, otaMarketInsights } from '../data/ota';

const breadcrumbs = [
  { name: 'OTA Advertising', href: '/ota-advertising' },
];

const platformLogos: Record<string, { letter: string; bg: string; text: string }> = {
  booking: { letter: 'B', bg: 'bg-blue-600', text: 'text-white' },
  expedia: { letter: 'E', bg: 'bg-yellow-500', text: 'text-gray-900' },
  tripadvisor: { letter: 'T', bg: 'bg-emerald-500', text: 'text-white' },
  google: { letter: 'G', bg: 'bg-red-500', text: 'text-white' },
  trivago: { letter: 'Tv', bg: 'bg-sky-500', text: 'text-white' },
  agoda: { letter: 'A', bg: 'bg-rose-600', text: 'text-white' },
  vrbo: { letter: 'V', bg: 'bg-indigo-600', text: 'text-white' },
  kayak: { letter: 'K', bg: 'bg-orange-500', text: 'text-white' },
  priceline: { letter: 'P', bg: 'bg-blue-800', text: 'text-white' },
  skyscanner: { letter: 'S', bg: 'bg-teal-500', text: 'text-white' },
};
---

<Layout
  breadcrumbs={breadcrumbs}
  title="OTA Advertising — AdvertisingSystems | Booking.com, Expedia, TripAdvisor & More"
  description="Manage and optimize advertising across Booking.com, Expedia, TripAdvisor, Google Hotel Ads, Trivago, and 10+ OTA platforms from one AI-powered dashboard. Coming soon."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'OTA Advertising',
    description: 'Manage and optimize advertising across Booking.com, Expedia, TripAdvisor, Google Hotel Ads, Trivago, and 10+ OTA platforms from one AI-powered dashboard.',
    url: 'https://advertisingsystems.ai/ota-advertising',
  }}
>
  <Navbar />
  <Breadcrumb items={breadcrumbs} />
  <main>
    <!-- Hero -->
    <section class="relative pt-28 pb-16 sm:pt-40 sm:pb-20 md:pt-48 md:pb-28 overflow-hidden" aria-labelledby="ota-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[min(600px,100vw)] h-[min(400px,60vh)] bg-[var(--hero-glow)] rounded-full blur-[128px]" aria-hidden="true"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center min-w-0">
        <div class="reveal inline-flex items-center gap-2 glass rounded-full px-4 py-2 sm:px-5 mb-6 sm:mb-8">
          <span class="w-2 h-2 bg-amber-400 rounded-full animate-pulse shrink-0"></span>
          <span class="text-xs sm:text-sm font-medium text-[var(--text-tertiary)]">Coming Soon — Join the Waitlist</span>
        </div>

        <h1 id="ota-heading" class="reveal text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em] break-words">
          <span class="text-[var(--text-primary)]">OTA Advertising</span>
        </h1>
        <p class="reveal mt-4 text-xl sm:text-2xl text-[var(--text-secondary)] font-medium">
          Every OTA. One dashboard. AI-optimized.
        </p>
        <p class="reveal mt-6 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          Manage sponsored listings across Booking.com, Expedia, TripAdvisor, Google Hotel Ads, Trivago, and more — with AI that optimizes bids, budgets, and targeting across every platform simultaneously.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg ">
            Join the Waitlist
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 btn-secondary font-semibold text-base px-8 py-3.5 rounded-lg">
            Book a Demo
          </a>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Market Stats -->
    <section class="py-12 sm:py-16 lg:py-20" aria-labelledby="stats-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
        <div class="text-center mb-12">
          <h2 id="stats-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            The OTA advertising <span class="text-[var(--text-primary)]">opportunity</span>
          </h2>
          <p class="reveal mt-4 text-lg text-[var(--text-tertiary)] max-w-xl mx-auto">OTAs spent $20B+ on marketing in 2025. Your property needs to compete.</p>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6">
          {otaStats.map((stat) => (
            <div class="reveal glass hover-glow rounded-2xl p-4 sm:p-6 lg:p-8 text-center min-w-0">
              <div class="text-3xl sm:text-4xl font-bold text-[var(--text-primary)] mb-2">{stat.value}</div>
              <div class="text-sm font-bold text-[var(--text-primary)] mb-1">{stat.label}</div>
              <div class="text-xs text-[var(--text-muted)] leading-relaxed">{stat.detail}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Pain Points -->
    <section class="py-28" aria-labelledby="pain-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
        <div class="text-center mb-16">
          <h2 id="pain-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Sound <span class="text-[var(--text-primary)]">familiar?</span>
          </h2>
          <p class="reveal mt-4 text-lg text-[var(--text-tertiary)] max-w-xl mx-auto">The OTA advertising problems every hotel faces.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {otaPainPoints.map((point) => (
            <div class="reveal glass hover-glow rounded-2xl p-8 border-t-4 border-red-400/30">
              <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={point.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-2">{point.title}</h3>
              <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">{point.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Supported OTA Platforms -->
    <section class="py-28" aria-labelledby="platforms-heading">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
        <div class="text-center mb-16">
          <h2 id="platforms-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Platforms we're <span class="text-[var(--text-primary)]">integrating</span>
          </h2>
          <p class="reveal mt-4 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto">All major OTAs and metasearch engines in one place. Manage sponsored listings, CPC bids, and performance across every platform.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
          {otaPlatforms.map((platform) => {
            const logo = platformLogos[platform.logo];
            return (
              <div class="reveal glass hover-glow rounded-2xl p-6 relative group">
                {platform.status === 'coming-soon' && (
                  <span class="absolute top-4 right-4 text-[10px] font-bold uppercase tracking-wider bg-amber-500/10 text-amber-500 px-2.5 py-1 rounded-full">Coming Soon</span>
                )}
                <div class="flex items-center gap-3 mb-4">
                  <div class={`w-10 h-10 rounded-lg ${logo.bg} ${logo.text} flex items-center justify-center font-bold text-sm shrink-0`}>
                    {logo.letter}
                  </div>
                  <div>
                    <h3 class="text-base font-bold text-[var(--text-primary)]">{platform.name}</h3>
                    <span class="text-xs font-medium text-[var(--text-muted)]">{platform.adModel}</span>
                  </div>
                </div>
                <p class="text-sm text-[var(--text-tertiary)] leading-relaxed mb-4">{platform.description}</p>
                <div class="flex items-center gap-1.5 mb-3">
                  <svg class="w-3.5 h-3.5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                  </svg>
                  <span class="text-xs font-medium text-[var(--text-muted)]">{platform.reach}</span>
                </div>
                <ul class="space-y-1.5">
                  {platform.features.map((feature) => (
                    <li class="flex items-start gap-2 text-xs text-[var(--text-tertiary)]">
                      <svg class="w-3.5 h-3.5 text-[var(--text-primary)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- App Mockup: Unified OTA Dashboard -->
    <section class="py-28" aria-labelledby="mockup-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
        <div class="text-center mb-16">
          <h2 id="mockup-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            One dashboard for <span class="text-[var(--text-primary)]">every OTA.</span>
          </h2>
        </div>

        <div class="reveal glass rounded-2xl overflow-hidden shadow-2xl">
          <div class="flex items-center gap-2 px-5 py-3.5 border-b border-[var(--browser-border)] bg-[var(--browser-chrome-bg)]">
            <div class="flex gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
            </div>
            <div class="flex-1 ml-3">
              <div class="bg-[var(--browser-url-bg)] rounded-md px-3 py-1 text-xs text-[var(--browser-url-text)] max-w-xs">app.advertisingsystems.ai/ota</div>
            </div>
          </div>
          <div class="p-6 sm:p-8 bg-[var(--surface-alt)]">
            <!-- OTA Status Bar -->
            <div class="glass rounded-lg p-4 mb-6 flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-[var(--surface-alt)] flex items-center justify-center">
                <span class="w-3 h-3 bg-[var(--text-muted)] rounded-full animate-pulse"></span>
              </div>
              <div class="flex-1">
                <div class="text-sm font-semibold text-[var(--text-primary)]">OTA Campaign Manager</div>
                <div class="text-xs text-[var(--text-muted)]">6 platforms connected &middot; 42 active campaigns &middot; AI optimizing</div>
              </div>
              <span class="text-xs font-semibold bg-amber-500/10 text-amber-500 px-3 py-1 rounded-full">Preview Mode</span>
            </div>

            <!-- OTA Performance Cards -->
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
              <div class="glass rounded-lg p-3">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-6 h-6 rounded bg-blue-600 text-white flex items-center justify-center text-[10px] font-bold">B</div>
                  <span class="text-xs font-semibold text-[var(--text-primary)]">Booking.com</span>
                </div>
                <div class="text-lg font-bold text-[var(--text-primary)]">4.8x ROAS</div>
                <div class="text-xs text-[var(--text-muted)]">$1.24 avg CPC &middot; 312 clicks</div>
              </div>
              <div class="glass rounded-lg p-3">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-6 h-6 rounded bg-yellow-500 text-gray-900 flex items-center justify-center text-[10px] font-bold">E</div>
                  <span class="text-xs font-semibold text-[var(--text-primary)]">Expedia</span>
                </div>
                <div class="text-lg font-bold text-[var(--text-primary)]">5.2x ROAS</div>
                <div class="text-xs text-[var(--text-muted)]">$0.98 avg CPC &middot; 487 clicks</div>
              </div>
              <div class="glass rounded-lg p-3">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-6 h-6 rounded bg-emerald-500 text-white flex items-center justify-center text-[10px] font-bold">T</div>
                  <span class="text-xs font-semibold text-[var(--text-primary)]">TripAdvisor</span>
                </div>
                <div class="text-lg font-bold text-[var(--text-primary)]">3.9x ROAS</div>
                <div class="text-xs text-[var(--text-muted)]">$1.96 avg CPC &middot; 189 clicks</div>
              </div>
            </div>

            <!-- AI Suggestions -->
            <div class="space-y-3 mb-6">
              <div class="glass rounded-lg p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="w-1.5 h-1.5 bg-[var(--text-muted)] rounded-full"></span>
                      <span class="text-xs font-semibold text-[var(--text-primary)] uppercase">AI Recommendation</span>
                    </div>
                    <div class="text-sm font-medium text-[var(--text-primary)]">Shift $280 from Booking.com to Expedia — higher ROAS this week</div>
                    <div class="text-xs text-[var(--text-muted)] mt-1">Cross-OTA Budget &middot; AI Engine &middot; 8 min ago</div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-sm font-bold text-[var(--text-primary)]">+18% ROAS</div>
                    <div class="text-xs text-[var(--text-muted)]">Est. impact</div>
                  </div>
                </div>
              </div>
              <div class="glass rounded-lg p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="w-1.5 h-1.5 bg-amber-400 rounded-full"></span>
                      <span class="text-xs font-semibold text-amber-500 uppercase">Occupancy Alert</span>
                    </div>
                    <div class="text-sm font-medium text-[var(--text-primary)]">85% occupancy Mar 21-24 — pausing Booking.com ads for those dates</div>
                    <div class="text-xs text-[var(--text-muted)] mt-1">Occupancy Pacing &middot; Auto-Applied &middot; 23 min ago</div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-sm font-bold text-amber-500">$140 saved</div>
                    <div class="text-xs text-[var(--text-muted)]">Avoided waste</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Performance Summary -->
            <div class="grid grid-cols-3 gap-4">
              <div class="glass rounded-lg p-4 text-center">
                <div class="text-xs text-[var(--text-muted)] mb-1">Total OTA ROAS</div>
                <div class="text-2xl font-bold text-[var(--text-primary)]">4.6x</div>
                <div class="mt-2 h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="width: 78%"></div>
                </div>
              </div>
              <div class="glass rounded-lg p-4 text-center">
                <div class="text-xs text-[var(--text-muted)] mb-1">Budget Saved</div>
                <div class="text-2xl font-bold text-[var(--text-primary)]">$2.4K</div>
                <div class="mt-2 h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="width: 65%"></div>
                </div>
              </div>
              <div class="glass rounded-lg p-4 text-center">
                <div class="text-xs text-[var(--text-muted)] mb-1">Platforms Active</div>
                <div class="text-2xl font-bold text-[var(--text-primary)]">6</div>
                <div class="mt-2 h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="width: 60%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Capabilities -->
    <section class="py-28" aria-labelledby="capabilities-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
        <div class="text-center mb-16">
          <h2 id="capabilities-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            What you'll <span class="text-[var(--text-primary)]">get</span>
          </h2>
          <p class="reveal mt-4 text-lg text-[var(--text-tertiary)] max-w-xl mx-auto">AI-powered OTA advertising management, built into your existing workflow.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {otaCapabilities.map((cap) => (
            <div class="reveal glass hover-glow rounded-2xl p-8">
              <div class="w-12 h-12 rounded-xl bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-[var(--text-tertiary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={cap.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-2">{cap.title}</h3>
              <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">{cap.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Market Landscape -->
    <section class="py-28" aria-labelledby="market-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
        <div class="text-center mb-16">
          <h2 id="market-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            The OTA <span class="text-[var(--text-primary)]">landscape</span>
          </h2>
          <p class="reveal mt-4 text-lg text-[var(--text-tertiary)] max-w-xl mx-auto">OTAs invest billions in marketing. Your property competes against that spend for every booking.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {otaMarketInsights.map((insight) => (
            <div class="reveal glass hover-glow rounded-2xl p-6">
              <div class="text-2xl font-bold text-[var(--text-primary)] mb-1">{insight.spend}</div>
              <h3 class="text-base font-bold text-[var(--text-primary)] mb-2">{insight.title}</h3>
              <p class="text-xs text-[var(--text-tertiary)] leading-relaxed">{insight.detail}</p>
            </div>
          ))}
        </div>

        <div class="reveal glass rounded-2xl p-8 mt-10">
          <h3 class="text-lg font-bold text-[var(--text-primary)] mb-4">How OTA Advertising Works</h3>
          <div class="grid sm:grid-cols-3 gap-6">
            <div>
              <div class="w-8 h-8 rounded-lg bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mb-3">
                <span class="text-sm font-bold text-[var(--text-tertiary)]">1</span>
              </div>
              <h4 class="text-sm font-bold text-[var(--text-primary)] mb-1">Bid for Placement</h4>
              <p class="text-xs text-[var(--text-tertiary)] leading-relaxed">Properties bid CPC or CPA to appear in premium positions within OTA search results. Higher bids = higher visibility.</p>
            </div>
            <div>
              <div class="w-8 h-8 rounded-lg bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mb-3">
                <span class="text-sm font-bold text-[var(--text-tertiary)]">2</span>
              </div>
              <h4 class="text-sm font-bold text-[var(--text-primary)] mb-1">Travelers Click</h4>
              <p class="text-xs text-[var(--text-tertiary)] leading-relaxed">When a traveler searches for accommodation, your sponsored listing appears prominently. You pay only when they click (CPC) or book (CPA).</p>
            </div>
            <div>
              <div class="w-8 h-8 rounded-lg bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mb-3">
                <span class="text-sm font-bold text-[var(--text-tertiary)]">3</span>
              </div>
              <h4 class="text-sm font-bold text-[var(--text-primary)] mb-1">Convert & Measure</h4>
              <p class="text-xs text-[var(--text-tertiary)] leading-relaxed">Track bookings, revenue, and ROAS per platform. AdvertisingSystems unifies this data and optimizes bids across all OTAs automatically.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- How We Compare -->
    <section class="py-28" aria-labelledby="compare-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
        <div class="text-center mb-16">
          <h2 id="compare-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
