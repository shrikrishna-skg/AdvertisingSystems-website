---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FAQSection from '../components/FAQSection.astro';
import { bookDemoFaqs } from '../data/page-faqs';

const benefits = [
  'Personalized walk-through of all 5 modules',
  'See real data for your industry',
  'Custom ROI projection for your budget',
  'No credit card required',
  'Cancel anytime — no commitments',
];

const trustStats = [
  { value: 'Bank-level Security', label: 'Your data is safe' },
  { value: '2,000+', label: 'Businesses Trust Us' },
  { value: '99.9%', label: 'Uptime' },
];

const pathStats = [
  { value: '2,000+', label: 'Businesses Trust Us' },
  { value: '14 Days', label: 'Free Trial' },
  { value: '<5 min', label: 'Setup Time' },
  { value: '24/7', label: 'Support' },
];

const locationOptions = [
  { value: '', label: 'Select...' },
  { value: '1', label: '1' },
  { value: '2-5', label: '2-5' },
  { value: '6-20', label: '6-20' },
  { value: '21-100', label: '21-100' },
  { value: '100+', label: '100+' },
];
---

<Layout
  title="Book a Demo — AdvertisingSystems | See It in Action"
  description="Schedule a personalized demo of AdvertisingSystems. See how AI-powered advertising management can transform your campaigns in just 30 minutes."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Book a Demo — AdvertisingSystems',
    url: 'https://advertisingsystems.ai/book-demo',
    potentialAction: {
      '@type': 'ReserveAction',
      name: 'Book a Demo',
      target: 'https://advertisingsystems.ai/book-demo'
    }
  }}
>
  <Navbar />

  <!-- Hero: two columns — left content, right form (ReputationSystems style) -->
  <section class="book-demo-hero relative min-h-[100vh] flex flex-col lg:flex-row" aria-labelledby="demo-hero-heading">
    <div class="book-demo-hero-bg absolute inset-0"></div>

    <!-- Left column: info -->
    <div class="relative z-10 flex-1 flex flex-col justify-center px-4 sm:px-6 lg:px-12 xl:px-16 py-16 lg:py-24">
      <div class="max-w-xl">
        <span class="inline-block rounded-full bg-white/10 backdrop-blur-sm text-white text-sm font-medium px-4 py-2 mb-6">
          Get Started in Minutes
        </span>
        <h1 id="demo-hero-heading" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight tracking-[-0.03em]">
          Book Your Personalized Demo
        </h1>
        <p class="mt-5 text-lg text-white/90 leading-relaxed">
          We'll walk you through every module, show you real data for your industry, and answer all your questions.
        </p>
        <ul class="mt-8 space-y-4" aria-label="Benefits">
          {benefits.map((text) => (
            <li class="flex items-start gap-3 text-white">
              <svg class="w-5 h-5 text-[var(--text-tertiary)] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span>{text}</span>
            </li>
          ))}
        </ul>
        <div class="mt-10 flex flex-wrap gap-8 text-white/90">
          {trustStats.map(({ value, label }) => (
            <div>
              <span class="font-semibold">{value}</span>
              <span class="text-sm ml-1">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Right column: form card -->
    <div class="relative z-10 flex-shrink-0 w-full lg:max-w-[480px] flex items-start justify-center lg:justify-end px-4 sm:px-6 lg:px-12 xl:px-16 py-12 lg:py-24">
      <div class="w-full max-w-md bg-white rounded-2xl shadow-xl p-6 sm:p-8">
        <h2 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight">Book Your Demo</h2>
        <p class="mt-1.5 text-sm text-slate-500">Tell us about your business and pick a time that works for you.</p>

        <form id="book-demo-form" action="/api/book-demo" method="POST" class="mt-6 space-y-5" aria-label="Demo request form">
          <div>
            <label for="demo-name" class="block text-sm font-medium text-slate-700 mb-1.5">Full Name</label>
            <div class="demo-input-wrap">
              <span class="demo-input-icon" aria-hidden="true">
                <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
              </span>
              <input type="text" id="demo-name" name="name" required autocomplete="name" placeholder="John Smith"
                class="demo-input w-full rounded-lg border border-slate-200 bg-white pl-10 pr-4 py-3.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-link)] focus:border-[var(--color-link)] transition-colors" />
            </div>
          </div>
          <div>
            <label for="demo-email" class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
            <div class="demo-input-wrap">
              <span class="demo-input-icon" aria-hidden="true">
                <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
              </span>
              <input type="email" id="demo-email" name="email" required autocomplete="email" placeholder="john@company.com"
                class="demo-input w-full rounded-lg border border-slate-200 bg-white pl-10 pr-4 py-3.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-link)] focus:border-[var(--color-link)] transition-colors" />
            </div>
          </div>
          <div>
            <label for="demo-phone" class="block text-sm font-medium text-slate-700 mb-1.5">Phone Number</label>
            <div class="demo-input-wrap">
              <span class="demo-input-icon" aria-hidden="true">
                <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              </span>
              <input type="tel" id="demo-phone" name="phone" autocomplete="tel" placeholder="(555) 000-0000"
                class="demo-input w-full rounded-lg border border-slate-200 bg-white pl-10 pr-4 py-3.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-link)] focus:border-[var(--color-link)] transition-colors" />
            </div>
          </div>
          <div>
            <label for="demo-company" class="block text-sm font-medium text-slate-700 mb-1.5">Business Name</label>
            <div class="demo-input-wrap">
              <span class="demo-input-icon" aria-hidden="true">
                <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21m6-18v18m-18-7v18" /></svg>
              </span>
              <input type="text" id="demo-company" name="company" required autocomplete="organization" placeholder="Acme Inc."
                class="demo-input w-full rounded-lg border border-slate-200 bg-white pl-10 pr-4 py-3.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-link)] focus:border-[var(--color-link)] transition-colors" />
            </div>
          </div>
          <div>
            <label for="demo-locations" class="block text-sm font-medium text-slate-700 mb-1.5">Number of Locations</label>
            <div class="demo-input-wrap demo-select-wrap">
              <select id="demo-locations" name="number_of_locations"
                class="demo-input w-full rounded-lg border border-slate-200 bg-white pl-4 pr-10 py-3.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[var(--color-link)] focus:border-[var(--color-link)] transition-colors appearance-none cursor-pointer">
                {locationOptions.map((opt) => (
                  <option value={opt.value} disabled={!opt.value}>{opt.label}</option>
                ))}
              </select>
              <span class="demo-select-chevron" aria-hidden="true">
                <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </div>
          </div>

          <!-- Preferred Date & Time: calendar widget -->
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Preferred Date & Time</label>
            <div class="demo-calendar rounded-lg border border-slate-200 bg-white p-4">
              <div class="flex items-center justify-between mb-4">
                <button type="button" id="calendar-prev" class="p-1.5 rounded-lg text-slate-500 hover:bg-slate-100 hover:text-slate-700 transition-colors" aria-label="Previous month">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                </button>
                <span id="calendar-month-year" class="text-sm font-semibold text-slate-800">March 2026</span>
                <button type="button" id="calendar-next" class="p-1.5 rounded-lg text-slate-500 hover:bg-slate-100 hover:text-slate-700 transition-colors" aria-label="Next month">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </button>
              </div>
              <div class="grid grid-cols-7 gap-0.5 mb-2">
                {['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'].map((d) => (
                  <span class="text-center text-xs font-medium text-slate-400 py-1">{d}</span>
                ))}
              </div>
              <div id="calendar-grid" class="grid grid-cols-7 gap-0.5 text-sm"></div>
              <div class="mt-3 pt-3 border-t border-slate-100">
                <label for="demo-time" class="sr-only">Time</label>
                <select id="demo-time" name="preferred_time"
                  class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-link)] focus:border-[var(--color-link)]">
                  <option value="">Select a date first</option>
                </select>
                <p id="demo-time-hint" class="mt-1 text-xs text-slate-500 hidden">Loading available times…</p>
              </div>
            </div>
            <input type="hidden" id="demo-preferred-datetime" name="preferred_datetime" />
          </div>

          <div>
            <label for="demo-message" class="block text-sm font-medium text-slate-700 mb-1.5">Anything else we should know?</label>
            <textarea id="demo-message" name="message" rows="3" placeholder="Tell us about your advertising goals..."
              class="demo-input w-full rounded-lg border border-slate-200 bg-white px-4 py-3.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--color-link)] focus:border-[var(--color-link)] transition-colors resize-none"></textarea>
          </div>

          <div id="form-message" class="hidden text-sm rounded-lg p-3" role="alert"></div>

          <button type="submit" id="demo-submit"
            class="w-full inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-6 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed">
            Book My Demo
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </button>

          <p class="text-center">
            <a href="/#pricing" class="text-sm text-slate-500 hover:text-slate-600">← Back to options</a>
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- Trust band: white background -->
  <section class="bg-white py-12 sm:py-16 border-y border-slate-100" aria-label="Trust indicators">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        {pathStats.map(({ value, label }) => (
          <div>
            <div class="text-2xl sm:text-3xl font-bold text-slate-900">{value}</div>
            <div class="text-sm text-slate-500 mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA banner -->
  <section class="bg-slate-900 py-16 sm:py-20" aria-label="Call to action">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white tracking-tight">Ready to Master Your Advertising?</h2>
      <p class="mt-4 text-lg text-white/80">Book a personalized demo and see AdvertisingSystems in action.</p>
      <a href="#book-demo-form" class="mt-8 inline-flex items-center justify-center gap-2 btn-secondary font-semibold px-8 py-3.5 rounded-lg transition-colors">
        Book Your Demo
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <FAQSection title="Common questions" faqs={bookDemoFaqs} name="book-demo-faq" />
  <Footer />

  <style>
    .book-demo-hero-bg {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
    }
    html.dark .book-demo-hero-bg {
      background: linear-gradient(135deg, #020617 0%, #0f172a 50%, #020617 100%);
    }
    .demo-input::placeholder {
      color: #94a3b8;
    }
    .demo-input-wrap {
      position: relative;
    }
    .demo-input-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .demo-select-wrap {
      position: relative;
    }
    .demo-select-chevron {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .calendar-day {
      position: relative;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 500;
      transition: background 0.15s, color 0.15s;
    }
    .calendar-day:hover:not(.calendar-day-empty):not(.calendar-day-past) {
      background: #f1f5f9;
    }
    .calendar-day-empty {
      cursor: default;
      visibility: hidden;
    }
    .calendar-day-past {
      color: #94a3b8;
      cursor: default;
      font-weight: 400;
    }
    .calendar-day-selected {
      background: rgba(16, 185, 129, 0.15);
      color: #0f172a;
    }
    .calendar-day-selected::after {
      content: '';
      position: absolute;
      bottom: 2px;
      left: 50%;
      transform: translateX(-50%);
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: #10B981;
    }
    .calendar-day-today {
      font-weight: 600;
      color: #0f172a;
    }
  </style>

  <script>
    const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
    let calendarDate = new Date();
    let selectedDate = null;

    const gridEl = document.getElementById('calendar-grid');
    const monthYearEl = document.getElementById('calendar-month-year');
    const prevBtn = document.getElementById('calendar-prev');
    const nextBtn = document.getElementById('calendar-next');
    const datetimeHidden = document.getElementById('demo-preferred-datetime');
    const timeSelect = document.getElementById('demo-time');
    const timeHint = document.getElementById('demo-time-hint');
    const form = document.getElementById('book-demo-form');
    const submitBtn = document.getElementById('demo-submit');
    const messageEl = document.getElementById('form-message');

    function slotToLabel(slot) {
      const [h, m] = slot.split(':').map(Number);
      if (h === 12) return `12:${m ? String(m).padStart(2, '0') : '00'} PM`;
      if (h > 12) return `${h - 12}:${m ? String(m).padStart(2, '0') : '00'} PM`;
      return `${h}:${m ? String(m).padStart(2, '0') : '00'} AM`;
    }

    function pad(n) { return n < 10 ? '0' + n : String(n); }
    function toYMD(d) { return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()); }
    function isSameDay(a, b) { return a && b && a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate(); }
    function isPast(d) {
      const t = new Date();
      t.setHours(0, 0, 0, 0);
      return d < t;
    }

    function renderCalendar() {
      if (!gridEl || !monthYearEl) return;
      const year = calendarDate.getFullYear();
      const month = calendarDate.getMonth();
      monthYearEl.textContent = `${MONTHS[month]} ${year}`;

      const first = new Date(year, month, 1);
      const last = new Date(year, month + 1, 0);
      const startPad = first.getDay();
      const daysInMonth = last.getDate();
      const today = new Date();
      today.setHours(0, 0, 0, 0);

      let html = '';
      for (let i = 0; i < startPad; i++) html += '<span class="calendar-day calendar-day-empty">·</span>';
      for (let d = 1; d <= daysInMonth; d++) {
        const date = new Date(year, month, d);
        const isPastDay = isPast(date);
        const isSelected = selectedDate && isSameDay(date, selectedDate);
        const isToday = isSameDay(date, today);
        let cls = 'calendar-day';
        if (isPastDay) cls += ' calendar-day-past';
        if (isSelected) cls += ' calendar-day-selected';
        if (isToday && !isSelected) cls += ' calendar-day-today';
        const dateStr = toYMD(date);
        html += `<button type="button" class="${cls}" data-date="${dateStr}" ${isPastDay ? 'disabled' : ''}>${d}</button>`;
      }
      gridEl.innerHTML = html;

      gridEl.querySelectorAll('.calendar-day[data-date]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dateStr = btn.getAttribute('data-date');
          if (!dateStr) return;
          selectedDate = new Date(dateStr + 'T12:00:00');
          renderCalendar();
          fetchAvailability(selectedDate);
        });
      });
    }

    function updatePreferredDatetime() {
      if (!datetimeHidden || !timeSelect) return;
      if (selectedDate && timeSelect.value) {
        datetimeHidden.value = toYMD(selectedDate) + 'T' + timeSelect.value + ':00';
      } else {
        datetimeHidden.value = '';
      }
    }

    async function fetchAvailability(date) {
      if (!timeSelect || !timeHint) return;
      const dateStr = toYMD(date);
      timeHint.classList.remove('hidden');
      timeHint.textContent = 'Loading available times…';
      timeSelect.innerHTML = '<option value="">Loading…</option>';
      timeSelect.disabled = true;
      try {
        const res = await fetch(`/api/calendar-availability?date=${encodeURIComponent(dateStr)}`);
        const data = await res.json().catch(() => ({}));
        const slots = Array.isArray(data.slots) ? data.slots : [];
        timeSelect.innerHTML = '';
        if (slots.length === 0) {
          timeSelect.innerHTML = '<option value="">No slots available this day</option>';
        } else {
          slots.forEach((slot, i) => {
            const opt = document.createElement('option');
            opt.value = slot;
            opt.textContent = slotToLabel(slot);
            if (i === 0) opt.selected = true;
            timeSelect.appendChild(opt);
          });
        }
        timeSelect.disabled = false;
        updatePreferredDatetime();
      } catch {
        timeSelect.innerHTML = '<option value="10:00">10:00 AM</option>';
        timeSelect.disabled = false;
        updatePreferredDatetime();
      }
      timeHint.classList.add('hidden');
    }

    prevBtn?.addEventListener('click', () => {
      calendarDate.setMonth(calendarDate.getMonth() - 1);
      renderCalendar();
    });
    nextBtn?.addEventListener('click', () => {
      calendarDate.setMonth(calendarDate.getMonth() + 1);
      renderCalendar();
    });
    timeSelect?.addEventListener('change', updatePreferredDatetime);

    renderCalendar();

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      updatePreferredDatetime();
      if (!submitBtn || !messageEl) return;
      submitBtn.disabled = true;
      messageEl.classList.add('hidden');
      messageEl.textContent = '';

      const formData = new FormData(form);
      const body = {};
      formData.forEach((value, key) => {
        if (typeof value === 'string' && value.trim()) body[key] = value.trim();
      });
      const pref = body.preferred_datetime;
      if (!pref && selectedDate && timeSelect) {
        body.preferred_datetime = toYMD(selectedDate) + 'T' + (timeSelect.value || '10:00') + ':00';
      }
      delete body.preferred_date;
      delete body.preferred_time;

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok) {
          messageEl.textContent = data.message || "Thanks! We'll be in touch to confirm your demo.";
          messageEl.className = 'text-sm rounded-lg p-3 bg-[var(--surface-alt)] text-[var(--text-primary)] border border-[var(--border)]';
          messageEl.classList.remove('hidden');
          form.reset();
          selectedDate = null;
          if (datetimeHidden) datetimeHidden.value = '';
          if (timeSelect) {
            timeSelect.innerHTML = '<option value="">Select a date first</option>';
            timeSelect.value = '';
          }
          renderCalendar();
        } else {
          messageEl.textContent = data.error || 'Something went wrong. Please try again or email us.';
          messageEl.className = 'text-sm rounded-lg p-3 bg-red-500/10 text-red-700';
          messageEl.classList.remove('hidden');
        }
      } catch {
        messageEl.textContent = 'Network error. Please try again.';
        messageEl.className = 'text-sm rounded-lg p-3 bg-red-500/10 text-red-700';
        messageEl.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>
</Layout>
