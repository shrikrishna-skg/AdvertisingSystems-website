---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import { featuresIndexFaqs } from '../../data/page-faqs';

const allFeatures = [
  {
    icon: 'campaign',
    title: 'Campaign Intelligence',
    desc: 'Unified command center for every ad platform. Launch, manage, and monitor campaigns across Google, Meta, and OTAs from a single dashboard.',
    href: '/features/campaign-management',
    stats: '14 campaigns in 20 min',
    color: 'royal-green',
  },
  {
    icon: 'ai',
    title: 'AI Optimization Engine',
    desc: 'Autonomous bidding, budget reallocation, and audience discovery powered by machine learning across 50,000+ data points.',
    href: '/features/ai-optimization',
    stats: '40% lower CPA',
    color: 'blue',
  },
  {
    icon: 'analytics',
    title: 'Performance Analytics',
    desc: 'Real-time dashboards, cross-channel attribution, and anomaly alerts. From data to decisions in seconds.',
    href: '/features/analytics',
    stats: '$180K attributed revenue',
    color: 'violet',
  },
  {
    icon: 'automation',
    title: 'Automation Studio',
    desc: 'Rules-based campaign automation. Set conditions, triggers, and actions — then let the system execute while you strategize.',
    href: '/features/automation',
    stats: '12hrs saved per week',
    color: 'amber',
  },
  {
    icon: 'budget',
    title: 'Budget Allocator',
    desc: 'AI-driven cross-channel budget distribution that maximizes ROAS by shifting spend to your best-performing campaigns in real time.',
    href: '/features/budget-intelligence',
    stats: '5.2x avg ROAS',
    color: 'rose',
  },
];

const withoutWith = [
  { without: 'Switching between 5+ ad platforms daily', with: 'One dashboard for every channel' },
  { without: 'Manual bid adjustments guessing game', with: 'AI optimizes bids 24/7 automatically' },
  { without: 'Spreadsheets for cross-channel reporting', with: 'Real-time unified analytics' },
  { without: 'Hours spent on repetitive campaign tasks', with: 'Automation handles it in seconds' },
  { without: 'Budget spread thin across channels blindly', with: 'AI allocates to top performers instantly' },
];
---

<Layout
  breadcrumbs={[{ name: 'Features', href: '/features' }]}
  title="Features — AdvertisingSystems | Campaign Intelligence, AI Optimization, Analytics & More"
  description="One platform for campaigns, AI optimization, analytics, automation, and budget allocation. See what each module does and how it helps you."
>
  <Navbar />
  <Breadcrumb items={[{ name: 'Features', href: '/features' }]} />
  <main>
    <!-- Hero -->
    <section class="relative pt-40 pb-20 sm:pt-48 sm:pb-28 overflow-hidden" aria-labelledby="features-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal inline-flex items-center gap-2 glass rounded-full px-5 py-2 mb-8">
          <span class="w-2 h-2 bg-royal-green-400 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-[var(--text-tertiary)]">5 Powerful Modules</span>
        </div>

        <h1 id="features-heading" class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Everything you need to <span class="text-gradient">master advertising.</span>
        </h1>
        <p class="reveal mt-6 text-lg sm:text-xl text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          Five integrated modules that replace your entire ad tech stack — from campaign creation to revenue attribution.
        </p>
      </div>
    </section>

    <!-- Feature Cards Grid -->
    <section class="py-20" aria-label="Feature modules">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {allFeatures.map((feature) => (
            <a href={feature.href} class="reveal group glass hover-glow rounded-2xl p-8 transition-all duration-300 block">
              <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-5 ${
                feature.color === 'royal-green' ? 'bg-royal-green-500/10 text-royal-green-600' :
                feature.color === 'blue' ? 'bg-blue-500/10 text-blue-600' :
                feature.color === 'violet' ? 'bg-violet-500/10 text-violet-600' :
                feature.color === 'amber' ? 'bg-amber-500/10 text-amber-600' :
                'bg-rose-500/10 text-rose-600'
              }`}>
                {feature.icon === 'campaign' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                  </svg>
                )}
                {feature.icon === 'ai' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                  </svg>
                )}
                {feature.icon === 'analytics' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                  </svg>
                )}
                {feature.icon === 'automation' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M21.015 4.356v4.992" />
                  </svg>
                )}
                {feature.icon === 'budget' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
              </div>

              <h3 class="text-xl font-bold text-[var(--text-primary)] mb-2 group-hover:text-royal-green-600 transition-colors">{feature.title}</h3>
              <p class="text-[var(--text-tertiary)] text-sm leading-relaxed mb-4">{feature.desc}</p>

              <div class="flex items-center justify-between">
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${
                  feature.color === 'royal-green' ? 'bg-royal-green-500/10 text-royal-green-600' :
                  feature.color === 'blue' ? 'bg-blue-500/10 text-blue-600' :
                  feature.color === 'violet' ? 'bg-violet-500/10 text-violet-600' :
                  feature.color === 'amber' ? 'bg-amber-500/10 text-amber-600' :
                  'bg-rose-500/10 text-rose-600'
                }`}>{feature.stats}</span>
                <svg class="w-5 h-5 text-[var(--text-muted)] group-hover:text-royal-green-500 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Without / With Comparison -->
    <section class="py-28" aria-labelledby="comparison-heading">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="comparison-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Before &amp; <span class="text-gradient">after</span> AdvertisingSystems.
          </h2>
        </div>

        <div class="space-y-4">
          {withoutWith.map((row) => (
            <div class="reveal grid md:grid-cols-2 gap-4">
              <div class="glass rounded-xl p-5 border-l-4 border-red-400/40">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                  <span class="text-sm text-[var(--text-tertiary)]">{row.without}</span>
                </div>
              </div>
              <div class="glass rounded-xl p-5 border-l-4 border-royal-green-400/40">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-royal-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span class="text-sm text-[var(--text-tertiary)]">{row.with}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Stats -->
    <section class="py-20" aria-label="Platform statistics">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="reveal glass rounded-xl p-6 text-center">
            <div class="text-3xl sm:text-4xl font-bold text-gradient">5.2x</div>
            <div class="text-sm text-[var(--text-muted)] mt-2">Average ROAS</div>
          </div>
          <div class="reveal glass rounded-xl p-6 text-center">
            <div class="text-3xl sm:text-4xl font-bold text-gradient">$5.2B+</div>
            <div class="text-sm text-[var(--text-muted)] mt-2">Ad Spend Managed</div>
          </div>
          <div class="reveal glass rounded-xl p-6 text-center">
            <div class="text-3xl sm:text-4xl font-bold text-gradient">38%</div>
            <div class="text-sm text-[var(--text-muted)] mt-2">Less Wasted Spend</div>
          </div>
          <div class="reveal glass rounded-xl p-6 text-center">
            <div class="text-3xl sm:text-4xl font-bold text-gradient">12hrs</div>
            <div class="text-sm text-[var(--text-muted)] mt-2">Saved Per Week</div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={featuresIndexFaqs} name="features-faq" />

    <div class="section-line"></div>

    <!-- CTA -->
    <section class="relative py-32 overflow-hidden" aria-labelledby="features-cta-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="features-cta-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Ready to see it <span class="text-gradient">in action?</span>
        </h2>
        <p class="reveal mt-6 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          Book a personalized demo and see how AdvertisingSystems can transform your advertising performance.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20">
            Book Your Demo
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/signup" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 btn-secondary font-semibold text-base px-8 py-3.5 rounded-lg">
            Start Free Trial
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
