---
const navLinks = [
  { text: 'Home', href: '/' },
  { text: 'Features', href: '#features', hasDropdown: true },
  { text: 'OTA Advertising', href: '/ota-advertising' },
  { text: 'Pricing', href: '/pricing' },
  { text: 'Blog', href: '/blog' },
  { text: 'About', href: '/about' },
];

const featureDropdownItems = [
  { title: 'Campaign Intelligence', desc: 'Unified command center for every ad platform', href: '/features/campaign-management', icon: 'dashboard', iconBg: 'bg-royal-blue-500/15', iconColor: 'text-royal-blue-600', subLinks: [{ text: 'Overview', href: '/features/campaign-management' }, { text: 'Pricing', href: '/#pricing' }] },
  { title: 'AI Optimization Engine', desc: 'Autonomous bid & budget optimization', href: '/features/ai-optimization', icon: 'sparkles', iconBg: 'bg-royal-blue-500/15', iconColor: 'text-royal-blue-600', subLinks: [{ text: 'Overview', href: '/features/ai-optimization' }, { text: 'Pricing', href: '/#pricing' }] },
  { title: 'Performance Analytics', desc: 'Real-time dashboards & revenue attribution', href: '/features/analytics', icon: 'chart', iconBg: 'bg-royal-blue-500/15', iconColor: 'text-royal-blue-600', subLinks: [{ text: 'Overview', href: '/features/analytics' }, { text: 'Pricing', href: '/#pricing' }] },
  { title: 'Automation Studio', desc: 'Rules-based campaign automation', href: '/features/automation', icon: 'automation', iconBg: 'bg-royal-blue-500/15', iconColor: 'text-royal-blue-600', subLinks: [{ text: 'Overview', href: '/features/automation' }, { text: 'Pricing', href: '/#pricing' }] },
  { title: 'Budget Allocator', desc: 'AI-driven cross-channel budget distribution', href: '/features/budget-intelligence', icon: 'budget', iconBg: 'bg-royal-blue-500/15', iconColor: 'text-royal-blue-600', subLinks: [{ text: 'Overview', href: '/features/budget-intelligence' }, { text: 'Pricing', href: '/#pricing' }] },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[var(--nav-bg)] backdrop-blur-2xl border-b border-[var(--nav-border)] transition-colors duration-300 min-w-0" role="banner">
  <nav class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 h-14 sm:h-[72px] flex items-center justify-between gap-2 min-w-0" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 sm:gap-2.5 shrink-0 min-w-0" aria-label="AdvertisingSystems home">
      <svg class="w-8 h-8 sm:w-9 sm:h-9 shrink-0 text-[var(--text-primary)]" viewBox="10 -1 44 58" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M26 16 A8 8 0 0 1 38 16" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" opacity="0.4"/>
        <path d="M22 11 A13 11 0 0 1 42 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.22"/>
        <line x1="32" y1="20" x2="22" y2="38" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        <line x1="32" y1="20" x2="42" y2="38" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        <line x1="22" y1="38" x2="14" y2="54" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.7"/>
        <line x1="42" y1="38" x2="50" y2="54" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.7"/>
        <line x1="22" y1="38" x2="42" y2="38" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.8"/>
        <line x1="14" y1="54" x2="50" y2="54" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.15"/>
        <circle cx="32" cy="20" r="4.2" fill="currentColor"/>
        <circle cx="22" cy="38" r="3.5" fill="currentColor" opacity="0.85"/>
        <circle cx="42" cy="38" r="3.5" fill="currentColor" opacity="0.85"/>
        <circle cx="14" cy="54" r="2.8" fill="currentColor" opacity="0.5"/>
        <circle cx="50" cy="54" r="2.8" fill="currentColor" opacity="0.5"/>
      </svg>
      <div class="flex flex-col min-w-0">
        <span class="text-base sm:text-lg font-bold text-[var(--text-primary)] leading-tight tracking-[-0.02em] truncate">Advertising<span class="text-[var(--text-primary)]">Systems</span></span>
        <span class="text-[9px] sm:text-[10px] font-medium text-[var(--text-muted)] uppercase tracking-[0.1em] leading-none hidden sm:block">by Multisystems</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <div class="relative group">
          <a
            href={link.href}
            class="px-3 py-2 text-sm font-medium text-[var(--text-tertiary)] hover:text-[var(--text-primary)] transition-colors rounded-lg inline-flex items-center gap-1"
          >
            {link.text}
            {link.hasDropdown && (
              <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
          {link.hasDropdown && (
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <div class="bg-[var(--surface-overlay)] backdrop-blur-2xl rounded-2xl border border-[var(--border)] shadow-2xl overflow-hidden w-[min(680px,calc(100vw-2rem))] max-h-[min(80vh,600px)] overflow-y-auto">
                <div class="flex">
                  <!-- Left: Feature list -->
                  <div class="flex-1 p-6 pr-4 min-w-0">
                    {featureDropdownItems.map((item) => (
                      <div class="flex gap-4 py-4 first:pt-0 last:pb-0 border-b border-[var(--border-subtle)] last:border-b-0 hover:bg-royal-blue-500/5 -mx-2 px-2 rounded-lg transition-colors group/item">
                        <div class={`w-10 h-10 rounded-lg flex items-center justify-center shrink-0 ${item.iconBg} ${item.iconColor}`}>
                          {item.icon === 'dashboard' && (
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z" /></svg>
                          )}
                          {item.icon === 'sparkles' && (
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
                          )}
                          {item.icon === 'chart' && (
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
                          )}
                          {item.icon === 'automation' && (
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                          )}
                          {item.icon === 'budget' && (
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
                          )}
                        </div>
                        <div class="min-w-0">
                          <a href={item.href} class="text-sm font-bold text-[var(--text-primary)] group-hover/item:text-royal-blue-600 transition-colors">{item.title}</a>
                          <p class="text-xs font-medium text-[var(--text-muted)] mt-0.5 leading-snug">{item.desc}</p>
                          <div class="flex flex-wrap gap-x-3 gap-y-0.5 mt-2">
                            {item.subLinks.map((s) => (
                              <a href={s.href} class="text-xs font-medium text-[var(--text-muted)] hover:text-royal-blue-600 transition-colors">{s.text}</a>
                            ))}
                          </div>
                        </div>
                      </div>
                    ))}
                    <a href="/features" class="flex items-center gap-2 py-3 mt-2 text-sm font-semibold link-secondary">
                      See all features
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                    </a>
                  </div>
                  <!-- Right: CTA cards -->
                  <div class="w-[220px] shrink-0 p-4 flex flex-col gap-3">
                    <!-- Book a Demo: dark card with gradient top line (color-shift on hover) -->
                    <a href="/book-demo" class="block rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow group/card">
                      <span class="block h-1.5 w-full bg-gradient-to-r from-royal-green-300 via-royal-green-500 to-royal-green-700 group-hover/card:from-royal-green-200 group-hover/card:via-royal-green-400 group-hover/card:to-royal-green-600 transition-all duration-300 rounded-t-xl" aria-hidden="true"></span>
                      <div class="bg-royal-green-900 p-4 text-white">
                        <svg class="w-5 h-5 text-royal-green-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
                        <span class="font-bold text-sm">Book a Demo</span>
                        <p class="text-xs text-white/80 mt-0.5">30-min walkthrough of the platform</p>
                        <span class="inline-flex items-center gap-1 mt-2 text-xs font-semibold text-royal-green-300 group-hover/card:gap-2 transition-all">Schedule now →</span>
                      </div>
                    </a>
                    <!-- Compare Plans -->
                    <a href="/#pricing" class="block rounded-xl border border-[var(--border)] bg-[var(--surface)] p-4 hover:border-royal-blue-500/30 hover:bg-royal-blue-500/5 transition-all group/card2">
                      <span class="font-bold text-sm text-[var(--text-primary)]">Compare Plans</span>
                      <p class="text-xs font-medium text-[var(--text-muted)] mt-0.5">See pricing for every plan</p>
                      <span class="inline-flex items-center gap-1 mt-2 text-xs font-semibold text-royal-blue-600 group-hover/card2:gap-2 transition-all">View pricing →</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Right side CTAs — Sign in, Sign Up, Book a Demo -->
    <div class="hidden lg:flex items-center gap-4">
      <a href="https://accounts.multisystems.ai/login" class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-link)] transition-colors">Sign in</a>
      <a href="https://accounts.multisystems.ai/signup" class="btn-cta-primary text-sm font-semibold text-white bg-royal-green-500 hover:bg-royal-green-600 px-5 py-2.5 rounded-lg transition-colors inline-flex items-center gap-1.5">
        <span class="cta-accent-line rounded-lg" aria-hidden="true"></span>
        <span class="relative">Sign Up</span>
      </a>
      <a href="/book-demo" class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-link)] transition-colors">Book a Demo</a>
    </div>

    <!-- Mobile menu toggle -->
    <label for="mobile-menu-toggle" class="lg:hidden cursor-pointer p-2 -mr-2" aria-label="Toggle menu">
      <svg class="w-6 h-6 text-[var(--text-tertiary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </label>
  </nav>
</header>

<!-- Mobile menu (CSS-only, no JS) -->
<input type="checkbox" id="mobile-menu-toggle" class="hidden peer" aria-hidden="true" />
<div class="fixed inset-0 z-40 bg-[var(--surface)] pt-14 sm:pt-[72px] pb-8 transform translate-x-full peer-checked:translate-x-0 transition-transform duration-300 lg:hidden overflow-y-auto" role="dialog" aria-label="Mobile navigation">
  <nav class="p-4 sm:p-6 flex flex-col gap-2 container-padding" aria-label="Mobile navigation">
    {navLinks.map((link) => (
      <a href={link.href} class="text-lg font-medium text-[var(--text-tertiary)] py-3 border-b border-[var(--border)] hover:text-royal-blue-500 transition-colors">
        {link.text}
      </a>
    ))}
    <div class="flex flex-col gap-3 mt-6">
      <a href="https://accounts.multisystems.ai/login" class="text-center text-sm font-medium text-[var(--color-link)] py-3">Sign in</a>
      <a href="https://accounts.multisystems.ai/signup" class="btn-cta-primary text-center text-sm font-semibold text-white bg-royal-green-500 hover:bg-royal-green-600 px-4 py-3 rounded-lg">Sign Up</a>
      <a href="/book-demo" class="text-center text-sm font-medium text-[var(--text-secondary)] py-3">Book a Demo</a>
    </div>
  </nav>
</div>
