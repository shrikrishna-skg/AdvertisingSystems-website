---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found — AdvertisingSystems"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <Navbar />
  <main>
    <section class="pt-36 pb-28 relative overflow-hidden min-h-[60vh] flex items-center">
      <div class="absolute inset-0 mesh-gradient opacity-20"></div>
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 relative text-center">
        <p class="reveal text-8xl sm:text-9xl font-bold text-[var(--text-primary)] tracking-[-0.04em] mb-6">404</p>
        <h1 class="reveal text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em] mb-4">
          Page not found
        </h1>
        <p class="reveal text-lg text-[var(--text-tertiary)] mb-10 max-w-md mx-auto">
          The page you're looking for doesn't exist or has been moved. Let's get you back on track.
        </p>
        <div class="reveal flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/" class="inline-block bg-royal-green-500 text-white font-semibold px-8 py-3 rounded-lg hover:bg-royal-green-600 transition-colors">
            Back to Homepage
          </a>
          <a href="/faq" class="inline-block btn-secondary font-semibold px-8 py-3 rounded-lg">
            FAQ
          </a>
          <a href="/knowledge-base" class="inline-block btn-secondary font-semibold px-8 py-3 rounded-lg">
            Knowledge Base
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
