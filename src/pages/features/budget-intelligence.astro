---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import { featureSubpageFaqs } from '../../data/page-faqs';

const painPoints = [
  {
    icon: 'M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5',
    title: 'Blind Budget Spreading',
    desc: "Dividing budget equally across channels with no data-driven rationale. You're guessing instead of investing where returns are highest.",
  },
  {
    icon: 'M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941',
    title: 'Top Performers Starved',
    desc: 'Your best campaigns hit budget caps by noon while mediocre campaigns have budget left to waste. Revenue opportunities lost daily.',
  },
  {
    icon: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Overspending on Underperformers',
    desc: 'Campaigns with declining returns keep running at full budget because nobody has time to continuously reallocate. Thousands wasted weekly.',
  },
];

const capabilities = [
  {
    icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z',
    title: 'AI Budget Distribution',
    desc: 'Machine learning allocates your total budget across channels and campaigns based on real-time performance, predicted returns, and diminishing-returns curves.',
  },
  {
    icon: 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z',
    title: 'Channel Scoring',
    desc: 'Every channel gets a real-time performance score factoring in ROAS, CPA, conversion volume, and growth trajectory — updated continuously.',
  },
  {
    icon: 'M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605',
    title: 'Spend Forecasting',
    desc: 'See exactly how budget changes would impact projected revenue before committing. Model scenarios and compare outcomes in seconds.',
  },
  {
    icon: 'M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0',
    title: 'Reallocation Alerts',
    desc: 'Instant notifications when the AI shifts budget between channels, with full reasoning. Approve changes or let them auto-apply.',
  },
];

const relatedFeatures = [
  { title: 'Campaign Intelligence', href: '/features/campaign-management', stat: '14 campaigns in 20min' },
  { title: 'AI Optimization Engine', href: '/features/ai-optimization', stat: '40% lower CPA' },
  { title: 'Performance Analytics', href: '/features/analytics', stat: '$180K attributed' },
  { title: 'Automation Studio', href: '/features/automation', stat: '12hrs saved/week' },
];
---

<Layout
  breadcrumbs={[{ name: 'Features', href: '/features' }, { name: 'Budget Allocator', href: '/features/budget-intelligence' }]}
  title="Budget Allocator — AdvertisingSystems | AI-Driven Budget Distribution"
  description="Every dollar in its highest-return channel. AI-driven cross-channel budget distribution that maximizes ROAS with 5.2x average returns."
>
  <Navbar />
  <Breadcrumb items={[{ name: 'Features', href: '/features' }, { name: 'Budget Allocator', href: '/features/budget-intelligence' }]} />
  <main>
    <!-- Hero -->
    <section class="relative pt-40 pb-20 sm:pt-48 sm:pb-28 overflow-hidden" aria-labelledby="budget-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal inline-flex items-center gap-2 glass rounded-full px-5 py-2 mb-8">
          <span class="w-2 h-2 bg-royal-green-400 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-[var(--text-tertiary)]">5.2x average ROAS</span>
        </div>

        <h1 id="budget-heading" class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Budget <span class="text-gradient">Allocator</span>
        </h1>
        <p class="reveal mt-4 text-xl sm:text-2xl text-[var(--text-secondary)] font-medium">
          Every dollar in its highest-return channel.
        </p>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          AI-driven cross-channel budget distribution that continuously shifts spend to your best-performing campaigns. Stop guessing where to invest — let the data decide.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20">
            See It In Action
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Pain Points -->
    <section class="py-28" aria-labelledby="pain-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="pain-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Sound <span class="text-gradient">familiar?</span>
          </h2>
          <p class="reveal mt-4 text-lg font-medium text-[var(--text-tertiary)] max-w-xl mx-auto">The budget allocation mistakes costing you revenue every day.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {painPoints.map((point) => (
            <div class="reveal glass hover-glow rounded-2xl p-8 border-t-4 border-red-400/30">
              <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={point.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-2">{point.title}</h3>
              <p class="text-sm font-medium text-[var(--text-tertiary)] leading-relaxed">{point.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- App Mockup -->
    <section class="py-28" aria-labelledby="mockup-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="mockup-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Budget allocation, <span class="text-gradient">optimized.</span>
          </h2>
        </div>

        <div class="reveal glass rounded-2xl overflow-hidden shadow-2xl">
          <div class="flex items-center gap-2 px-5 py-3.5 border-b border-[var(--browser-border)] bg-[var(--browser-chrome-bg)]">
            <div class="flex gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
            </div>
            <div class="flex-1 ml-3">
              <div class="bg-[var(--browser-url-bg)] rounded-md px-3 py-1 text-xs text-[var(--browser-url-text)] max-w-xs">app.advertisingsystems.ai/budget</div>
            </div>
          </div>
          <div class="p-6 sm:p-8 bg-[var(--surface-alt)]">
            <!-- Total Budget -->
            <div class="glass rounded-lg p-5 mb-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <div class="text-xs text-[var(--text-muted)] mb-1">Monthly Budget</div>
                  <div class="text-3xl font-bold text-[var(--text-primary)]">$50,000</div>
                </div>
                <div class="text-right">
                  <div class="text-xs text-[var(--text-muted)] mb-1">Projected Revenue</div>
                  <div class="text-3xl font-bold text-royal-green-500">$260,000</div>
                </div>
              </div>
              <div class="h-4 rounded-full bg-[var(--progress-track)] overflow-hidden flex">
                <div class="h-full bg-blue-500" style="width: 42%" title="Google Ads"></div>
                <div class="h-full bg-violet-500" style="width: 33%" title="Meta Ads"></div>
                <div class="h-full bg-amber-500" style="width: 18%" title="Booking.com"></div>
                <div class="h-full bg-royal-green-500" style="width: 7%" title="Reserve"></div>
              </div>
              <div class="flex items-center gap-6 mt-3 text-xs text-[var(--text-muted)]">
                <span class="flex items-center gap-1"><span class="w-2 h-2 bg-blue-500 rounded-full"></span> Google Ads 42%</span>
                <span class="flex items-center gap-1"><span class="w-2 h-2 bg-violet-500 rounded-full"></span> Meta Ads 33%</span>
                <span class="flex items-center gap-1"><span class="w-2 h-2 bg-amber-500 rounded-full"></span> Booking.com 18%</span>
                <span class="flex items-center gap-1"><span class="w-2 h-2 bg-royal-green-500 rounded-full"></span> Reserve 7%</span>
              </div>
            </div>
            <!-- Channel Cards -->
            <div class="grid grid-cols-3 gap-4 mb-6">
              <div class="glass rounded-lg p-4">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm font-semibold text-[var(--text-primary)]">Google Ads</span>
                  <span class="text-xs bg-blue-500/10 text-blue-500 px-2 py-0.5 rounded-full">Score: 94</span>
                </div>
                <div class="text-lg font-bold text-[var(--text-primary)] mb-1">$21,000</div>
                <div class="text-xs text-royal-green-500 mb-3">ROAS: 5.8x</div>
                <div class="h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-blue-400 to-blue-600" style="width: 94%"></div>
                </div>
                <div class="text-xs text-[var(--text-muted)] mt-2 flex items-center gap-1">
                  <svg class="w-3 h-3 text-royal-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                  +$2,400 from last month
                </div>
              </div>
              <div class="glass rounded-lg p-4">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm font-semibold text-[var(--text-primary)]">Meta Ads</span>
                  <span class="text-xs bg-violet-500/10 text-violet-500 px-2 py-0.5 rounded-full">Score: 87</span>
                </div>
                <div class="text-lg font-bold text-[var(--text-primary)] mb-1">$16,500</div>
                <div class="text-xs text-royal-green-500 mb-3">ROAS: 5.1x</div>
                <div class="h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-violet-400 to-violet-600" style="width: 87%"></div>
                </div>
                <div class="text-xs text-[var(--text-muted)] mt-2 flex items-center gap-1">
                  <svg class="w-3 h-3 text-royal-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                  +$1,800 from last month
                </div>
              </div>
              <div class="glass rounded-lg p-4">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm font-semibold text-[var(--text-primary)]">Booking.com</span>
                  <span class="text-xs bg-amber-500/10 text-amber-500 px-2 py-0.5 rounded-full">Score: 72</span>
                </div>
                <div class="text-lg font-bold text-[var(--text-primary)] mb-1">$9,000</div>
                <div class="text-xs text-royal-green-500 mb-3">ROAS: 4.2x</div>
                <div class="h-2 rounded-full bg-[var(--progress-track)] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-amber-400 to-amber-600" style="width: 72%"></div>
                </div>
                <div class="text-xs text-[var(--text-muted)] mt-2 flex items-center gap-1">
                  <svg class="w-3 h-3 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 4.5l15 15m0 0V8.25m0 11.25H8.25" /></svg>
                  -$600 from last month
                </div>
              </div>
            </div>
            <!-- Recent Reallocation -->
            <div class="glass rounded-lg p-4">
              <div class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-3">Recent AI Reallocations</div>
              <div class="space-y-2">
                <div class="flex items-center gap-3 text-sm">
                  <span class="w-1.5 h-1.5 bg-royal-green-400 rounded-full"></span>
                  <span class="text-[var(--text-tertiary)]">Shifted <span class="font-semibold text-[var(--text-primary)]">$1,200</span> from Booking.com to Google Ads</span>
                  <span class="text-xs text-[var(--text-muted)] ml-auto">2h ago</span>
                </div>
                <div class="flex items-center gap-3 text-sm">
                  <span class="w-1.5 h-1.5 bg-royal-green-400 rounded-full"></span>
                  <span class="text-[var(--text-tertiary)]">Increased Meta Ads budget by <span class="font-semibold text-[var(--text-primary)]">$800</span> from reserve</span>
                  <span class="text-xs text-[var(--text-muted)] ml-auto">5h ago</span>
                </div>
                <div class="flex items-center gap-3 text-sm">
                  <span class="w-1.5 h-1.5 bg-royal-green-400 rounded-full"></span>
                  <span class="text-[var(--text-tertiary)]">Reduced Booking.com daily cap by <span class="font-semibold text-[var(--text-primary)]">15%</span> — declining ROAS</span>
                  <span class="text-xs text-[var(--text-muted)] ml-auto">1d ago</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Capabilities -->
    <section class="py-28" aria-labelledby="capabilities-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="capabilities-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Key <span class="text-gradient">capabilities</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {capabilities.map((cap) => (
            <div class="reveal glass hover-glow rounded-2xl p-8">
              <div class="w-12 h-12 rounded-xl bg-royal-green-500/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={cap.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-2">{cap.title}</h3>
              <p class="text-sm font-medium text-[var(--text-tertiary)] leading-relaxed">{cap.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Testimonial -->
    <section class="py-28" aria-labelledby="testimonial-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal glass rounded-2xl p-10 sm:p-14">
          <svg class="w-10 h-10 text-royal-green-500/30 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
          </svg>
          <blockquote>
            <p id="testimonial-heading" class="text-xl sm:text-2xl font-medium text-[var(--text-primary)] leading-relaxed">
              "We went from 3.1x to 5.2x blended ROAS in the first month. The AI found budget inefficiencies we'd been blind to for years."
            </p>
          </blockquote>
          <div class="mt-8">
            <div class="font-semibold text-[var(--text-primary)]">David Thornton</div>
            <div class="text-sm font-medium text-[var(--text-muted)]">CMO, Coastal Luxury Resorts</div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Related Features -->
    <section class="py-28" aria-labelledby="related-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 id="related-heading" class="reveal text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Explore more <span class="text-gradient">features</span>
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relatedFeatures.map((feature) => (
            <a href={feature.href} class="reveal group glass hover-glow rounded-2xl p-6 transition-all duration-300 block">
              <h3 class="text-base font-bold text-[var(--text-primary)] mb-2 group-hover:text-royal-green-600 transition-colors">{feature.title}</h3>
              <span class="text-xs font-semibold bg-royal-green-500/10 text-royal-green-600 px-2.5 py-1 rounded-full">{feature.stat}</span>
              <div class="mt-4">
                <svg class="w-5 h-5 text-[var(--text-muted)] group-hover:text-royal-green-500 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={featureSubpageFaqs} name="budget-faq" />

    <div class="section-line"></div>

    <!-- CTA -->
    <section class="relative py-32 overflow-hidden" aria-labelledby="cta-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="cta-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Put every dollar to <span class="text-gradient">work.</span>
        </h2>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          See how Budget Allocator can maximize your ROAS with AI-driven spend distribution across every channel.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20">
            Book Your Demo
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/signup" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 btn-secondary font-semibold text-base px-8 py-3.5 rounded-lg">
            Start Free Trial
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
