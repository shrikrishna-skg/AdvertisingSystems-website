---
const pillars = [
  { title: 'Campaign Intelligence', desc: 'One command center for Google, Meta & OTAs. Launch and manage campaigns from a single screen.', href: '/features/campaign-management' },
  { title: 'AI Optimization', desc: 'Autonomous bidding and budget reallocation. Let AI find patterns and shift spend to top performers.', href: '/features/ai-optimization' },
  { title: 'Performance Analytics', desc: 'Real-time dashboards, revenue attribution, and anomaly alerts. From data to decisions in seconds.', href: '/features/analytics' },
  { title: 'Automation Studio', desc: 'Rules-based campaign automation. Scale without manual optimization hell.', href: '/features/automation' },
  { title: 'Budget Allocator', desc: 'AI-driven cross-channel budget distribution. Every dollar in the right place.', href: '/features/budget-intelligence' },
  { title: 'OTA Advertising', desc: 'Unify Booking.com, Expedia, TripAdvisor. One system for travel and hospitality ads.', href: '/ota-advertising' },
];
---

<section class="py-16 sm:py-24 bg-[var(--surface)]" aria-labelledby="pillars-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <h2 id="pillars-heading" class="reveal text-2xl sm:text-3xl lg:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
        Many ways to succeed with AdvertisingSystems
      </h2>
      <p class="reveal mt-4 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto">
        One platform. Every channel. Choose what you need and explore.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {pillars.map((item) => (
        <article class="reveal rounded-xl border border-[var(--border)] bg-[var(--surface-alt)] p-6 hover:border-[var(--border)] hover:shadow-md transition-all">
          <h3 class="text-lg font-bold text-[var(--text-primary)] mb-2">{item.title}</h3>
          <p class="text-[var(--text-tertiary)] text-sm leading-relaxed mb-4">{item.desc}</p>
          <a href={item.href} class="inline-flex items-center gap-1.5 link-secondary font-semibold text-sm">
            Explore {item.title.split(' ')[0]}
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
