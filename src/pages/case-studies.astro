---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { caseStudiesFaqs } from '../data/page-faqs';

const breadcrumbs = [{ name: 'Case Studies', href: '/case-studies' }];

const caseStudies = [
  {
    id: 'travel',
    industry: 'Travel & Hospitality',
    company: 'TravelCorp',
    headline: 'How TravelCorp increased ROAS by 340%',
    stat: '340%',
    statLabel: 'ROAS increase',
    description: 'TravelCorp was managing campaigns across Google Ads, Meta, and 3 OTAs with separate dashboards and manual bid adjustments. After switching to AdvertisingSystems, their AI-optimized bidding and unified reporting helped them reallocate budget to top-performing channels — tripling their return on ad spend in under 90 days.',
  },
  {
    id: 'ecommerce',
    industry: 'E-commerce',
    company: 'MetroRetail',
    headline: 'MetroRetail cut CPA by 52% in 30 days',
    stat: '52%',
    statLabel: 'CPA reduction',
    description: 'MetroRetail struggled with rising acquisition costs across their multi-channel ad strategy. AdvertisingSystems identified underperforming audience segments and automated budget reallocation, cutting their cost per acquisition by more than half within the first month.',
  },
  {
    id: 'technology',
    industry: 'Technology',
    company: 'GlobalTech',
    headline: 'GlobalTech unified 8 ad channels in one dashboard',
    stat: '8',
    statLabel: 'Channels unified',
    description: 'GlobalTech\'s marketing team was spending 15+ hours per week pulling reports from different platforms. With AdvertisingSystems, they consolidated Google Ads, Meta Ads, Microsoft Ads, TikTok, and 4 partner networks into a single real-time dashboard — saving over 60 hours per month.',
  },
];
---

<Layout
  title="Case Studies — AdvertisingSystems | Real Results From Real Customers"
  description="See how TravelCorp, MetroRetail, and GlobalTech cut CPA, raised ROAS, and saved hours with AI-powered advertising management."
  breadcrumbs={breadcrumbs}
>
  <Navbar />
  <Breadcrumb items={breadcrumbs} />
  <main>
    <!-- Hero -->
    <section class="pt-36 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 mesh-gradient opacity-30"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center">
          <h1 class="reveal text-4xl sm:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Customer <span class="text-gradient">Success Stories</span>
          </h1>
          <p class="reveal mt-5 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
            See how teams use AdvertisingSystems to drive measurable results across their advertising channels.
          </p>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Intro -->
    <section class="py-16" aria-labelledby="case-intro-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="case-intro-heading" class="reveal text-2xl sm:text-3xl font-bold text-[var(--text-primary)] tracking-[-0.02em]">
          Real teams. <span class="text-gradient">Real results.</span>
        </h2>
        <p class="reveal mt-4 text-lg font-medium text-[var(--text-tertiary)] leading-relaxed">
          Businesses like yours have improved ROAS, cut CPA, and saved hours by unifying Google, Meta, and OTA campaigns in one AI-powered platform. Browse by industry to find the story that fits.
        </p>
      </div>
    </section>

    <!-- Case Studies -->
    <section id="studies" class="pb-20" aria-label="Case studies">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap justify-center gap-2 mb-10">
          <a href="#studies" class="reveal px-4 py-2 rounded-full text-sm font-semibold bg-royal-green-500/15 text-royal-green-600 border border-royal-green-500/30 transition-colors">All</a>
          <a href="#travel" class="reveal px-4 py-2 rounded-full text-sm font-semibold text-[var(--text-tertiary)] hover:bg-royal-green-500/10 hover:text-royal-green-600 border border-[var(--border)] transition-colors">Travel &amp; Hospitality</a>
          <a href="#ecommerce" class="reveal px-4 py-2 rounded-full text-sm font-semibold text-[var(--text-tertiary)] hover:bg-royal-green-500/10 hover:text-royal-green-600 border border-[var(--border)] transition-colors">E-commerce</a>
          <a href="#technology" class="reveal px-4 py-2 rounded-full text-sm font-semibold text-[var(--text-tertiary)] hover:bg-royal-green-500/10 hover:text-royal-green-600 border border-[var(--border)] transition-colors">Technology</a>
        </div>

        <div class="space-y-8">
          {caseStudies.map((study) => (
            <article id={study.id} class="reveal glass rounded-2xl p-8 sm:p-10 hover:border-royal-green-500/20 transition-colors scroll-mt-24">
              <div class="flex flex-col lg:flex-row lg:items-start gap-8">
                <div class="flex-1">
                  <span class="inline-block glass text-xs font-semibold text-royal-green-600 px-3 py-1.5 rounded-full mb-4">
                    {study.industry}
                  </span>
                  <h2 class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)] tracking-[-0.02em] mb-4">
                    {study.headline}
                  </h2>
                  <p class="text-[var(--text-tertiary)] font-medium leading-relaxed mb-6">
                    {study.description}
                  </p>
                  <span class="inline-flex items-center gap-1.5 text-royal-green-600 font-semibold">
                    Key results
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </span>
                  <p class="text-xs text-[var(--text-muted)] mt-1">Full case study write-up coming soon.</p>
                </div>
              <div class="lg:shrink-0 lg:w-48 text-center glass rounded-xl p-6">
                <p class="text-4xl font-bold text-gradient tracking-[-0.03em]">{study.stat}</p>
                <p class="text-sm text-[var(--text-tertiary)] mt-1 font-medium">{study.statLabel}</p>
                <p class="text-xs text-[var(--text-muted)] mt-2">{study.company}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={caseStudiesFaqs} name="case-studies-faq" />

    <div class="section-line"></div>

    <!-- CTA -->
    <section class="relative py-32 overflow-hidden" aria-labelledby="case-cta-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>
      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="case-cta-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Get results <span class="text-gradient">like these.</span>
        </h2>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          Join 2,000+ businesses running their ads on AdvertisingSystems. Start free or book a personalized demo.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20">
            Book a demo
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/signup" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 text-[var(--text-secondary)] font-semibold text-base px-8 py-3.5 rounded-lg border border-[var(--border)] hover:border-royal-green-500/30 hover:text-royal-green-600 transition-colors">
            Start free trial
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
