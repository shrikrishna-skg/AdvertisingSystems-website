---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import { vsPageFaqs } from '../../data/page-faqs';

const breadcrumbs = [{ name: 'vs Manual Management', href: '/vs/manual' }];

const features = [
  { name: 'Cross-channel management', us: true, them: false },
  { name: 'AI-powered bidding', us: true, them: false },
  { name: 'Automated reporting', us: true, them: false },
  { name: 'Budget optimization', us: true, them: false },
  { name: '24/7 campaign monitoring', us: true, them: false },
  { name: 'Anomaly detection & alerts', us: true, them: false },
  { name: 'Real-time analytics', us: true, them: false },
  { name: 'Cross-channel attribution', us: true, them: false },
  { name: 'OTA integration', us: true, them: false },
  { name: 'Scalable campaign launch', us: true, them: false },
];

const advantages = [
  {
    title: 'Automation Over Spreadsheets',
    desc: 'Replace manual spreadsheet tracking with intelligent automation that manages campaigns across every channel simultaneously.',
    icon: 'automation',
  },
  {
    title: 'AI Optimization vs Guesswork',
    desc: 'Stop guessing which bids and budgets work. Our AI analyzes 50,000+ data points to make decisions backed by real performance data.',
    icon: 'ai',
  },
  {
    title: 'Real-Time vs Monthly Reports',
    desc: 'Why wait for month-end reports? Get live dashboards with instant anomaly alerts so you can act on performance shifts immediately.',
    icon: 'analytics',
  },
  {
    title: '24/7 Monitoring, Zero Effort',
    desc: 'Your campaigns run around the clock — your management should too. AI monitors and adjusts while you focus on strategy.',
    icon: 'monitor',
  },
];

const comparisons = [
  { label: 'Campaign Management', us: 'AI-powered automation', them: 'Manual spreadsheets' },
  { label: 'Optimization', us: 'Machine learning across 50K+ data points', them: 'Gut feeling & guesswork' },
  { label: 'Reporting', us: 'Real-time dashboards & alerts', them: 'Monthly manual reports' },
];
---

<Layout
  title="AdvertisingSystems vs Manual Advertising Management | Compare"
  description="See how AdvertisingSystems replaces manual advertising management with AI-powered automation, real-time analytics, and cross-channel optimization."
  breadcrumbs={breadcrumbs}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'AdvertisingSystems vs Manual Campaign Management',
    description: 'See how AdvertisingSystems replaces manual advertising management with AI-powered automation, real-time analytics, and cross-channel optimization.',
    url: 'https://advertisingsystems.ai/vs/manual',
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['h1', 'h2', '.glass']
    }
  }}
>
  <Navbar />
  <Breadcrumb items={breadcrumbs} />
  <main>
    <!-- Hero -->
    <section class="relative pt-40 pb-20 sm:pt-48 sm:pb-28 overflow-hidden">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal inline-flex items-center gap-2 glass rounded-full px-5 py-2 mb-8">
          <span class="w-2 h-2 bg-royal-green-400 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-[var(--text-tertiary)]">Comparison</span>
        </div>

        <h1 class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          AdvertisingSystems vs <span class="text-gradient">Manual Management</span>
        </h1>
        <p class="reveal mt-6 text-lg sm:text-xl font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          Ditch the spreadsheets and guesswork. See why teams switch from manual ad management to AI-powered automation.
        </p>
      </div>
    </section>

    <!-- Quick Comparison Summary -->
    <section class="py-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-6">
          {comparisons.map((item) => (
            <div class="reveal glass rounded-2xl p-6">
              <p class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-4">{item.label}</p>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-royal-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                  <span class="text-sm text-[var(--text-secondary)]">{item.us}</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  <span class="text-sm text-[var(--text-muted)]">{item.them}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Feature Comparison Table -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="reveal text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Feature-by-feature <span class="text-gradient">comparison</span>
          </h2>
        </div>

        <div class="reveal glass rounded-2xl overflow-hidden">
          <div class="grid grid-cols-3 gap-0">
            <div class="p-4 border-b border-[var(--border)] font-semibold text-[var(--text-primary)]">Feature</div>
            <div class="p-4 border-b border-[var(--border)] text-center font-semibold text-royal-green-600">AdvertisingSystems</div>
            <div class="p-4 border-b border-[var(--border)] text-center font-semibold text-[var(--text-muted)]">Manual</div>

            {features.map((f) => (
              <>
                <div class="p-4 border-b border-[var(--border)] text-sm text-[var(--text-secondary)]">{f.name}</div>
                <div class="p-4 border-b border-[var(--border)] flex justify-center">
                  {f.us ? (
                    <svg class="w-5 h-5 text-royal-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                  ) : (
                    <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  )}
                </div>
                <div class="p-4 border-b border-[var(--border)] flex justify-center">
                  {f.them ? (
                    <svg class="w-5 h-5 text-royal-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                  ) : (
                    <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  )}
                </div>
              </>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Key Advantages -->
    <section class="py-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="reveal text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Why teams <span class="text-gradient">switch</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {advantages.map((adv) => (
            <div class="reveal glass hover-glow rounded-2xl p-8">
              <div class="w-12 h-12 rounded-xl bg-royal-green-500/10 text-royal-green-600 flex items-center justify-center mb-5">
                {adv.icon === 'automation' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M21.015 4.356v4.992" /></svg>
                )}
                {adv.icon === 'ai' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>
                )}
                {adv.icon === 'analytics' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
                )}
                {adv.icon === 'monitor' && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                )}
              </div>
              <h3 class="text-xl font-bold text-[var(--text-primary)] mb-2">{adv.title}</h3>
              <p class="text-sm font-medium text-[var(--text-tertiary)] leading-relaxed">{adv.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={vsPageFaqs} name="vs-manual-faq" />

    <div class="section-line"></div>

    <!-- CTA -->
    <section class="relative py-32 overflow-hidden">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Switch to <span class="text-gradient">AdvertisingSystems</span>
        </h2>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          Stop managing ads manually. Let AI handle the heavy lifting while you focus on strategy and growth.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/signup" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20">
            Start Free Trial
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 btn-secondary font-semibold text-base px-8 py-3.5 rounded-lg">
            Book a Demo
          </a>
        </div>
        <p class="reveal mt-6 text-sm font-medium text-[var(--text-muted)]">No credit card required &middot; 14-day free trial &middot; Cancel anytime</p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
