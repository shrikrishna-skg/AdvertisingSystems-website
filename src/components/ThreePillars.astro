---
const pillars = [
  {
    title: 'Reach customers wherever they are',
    desc: 'Show up at the right time across Google, Meta, and OTAs. One platform finds your best-performing channels and maximizes conversions.',
  },
  {
    title: 'Track, learn, and optimize for ROI',
    desc: 'Track conversions and get clear audience insights. Budget-optimizing automation helps you capture new opportunities with the highest ROI.',
  },
  {
    title: 'Stay in full control of your budget',
    desc: 'Get recommendations, set your budget, and adjust at any time. Measure results and make the most of every ad dollar.',
  },
];
---

<section class="py-16 sm:py-24 bg-[var(--surface)]" aria-labelledby="three-pillars-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="three-pillars-heading" class="reveal text-center text-2xl sm:text-3xl lg:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em] mb-12 sm:mb-16">
      The power of one platform, for your business
    </h2>

    <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
      {pillars.map((item) => (
        <article class="reveal text-center">
          <h3 class="text-lg font-bold text-[var(--text-primary)] mb-3">{item.title}</h3>
          <p class="text-[var(--text-tertiary)] text-sm leading-relaxed">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
