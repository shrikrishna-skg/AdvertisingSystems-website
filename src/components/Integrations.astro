---
const platforms = [
  { name: 'Google Ads', domain: 'google.com', letter: 'G', color: 'bg-blue-500/10 text-blue-600' },
  { name: 'Meta Ads', domain: 'meta.com', letter: 'M', color: 'bg-indigo-500/10 text-indigo-600' },
  { name: 'Booking.com', domain: 'booking.com', letter: 'B', color: 'bg-blue-500/10 text-blue-600' },
  { name: 'Expedia', domain: 'expedia.com', letter: 'E', color: 'bg-yellow-500/10 text-yellow-600' },
  { name: 'TripAdvisor', domain: 'tripadvisor.com', letter: 'T', color: 'bg-[var(--surface-alt)] text-[var(--text-tertiary)] border border-[var(--border)]' },
  { name: 'Google Analytics', domain: 'google.com', letter: 'GA', color: 'bg-orange-500/10 text-orange-600' },
  { name: 'Instagram', domain: 'instagram.com', letter: 'IG', color: 'bg-pink-500/10 text-pink-600' },
  { name: 'Facebook', domain: 'facebook.com', letter: 'F', color: 'bg-blue-500/10 text-blue-600' },
  { name: 'TikTok', domain: 'tiktok.com', letter: 'TT', color: 'bg-slate-500/10 text-slate-600' },
  { name: 'LinkedIn', domain: 'linkedin.com', letter: 'Li', color: 'bg-blue-500/10 text-blue-600' },
  { name: 'YouTube', domain: 'youtube.com', letter: 'YT', color: 'bg-red-500/10 text-red-600' },
  { name: 'Airbnb', domain: 'airbnb.com', letter: 'A', color: 'bg-rose-500/10 text-rose-600' },
  { name: 'Hotels.com', domain: 'hotels.com', letter: 'H', color: 'bg-red-500/10 text-red-600' },
  { name: 'Bing Ads', domain: 'bing.com', letter: 'B', color: 'bg-teal-500/10 text-teal-600' },
  { name: 'X', domain: 'x.com', letter: 'X', color: 'bg-slate-500/10 text-slate-600' },
  { name: 'Pinterest', domain: 'pinterest.com', letter: 'P', color: 'bg-red-500/10 text-red-600' },
  { name: 'Trivago', domain: 'trivago.com', letter: 'Tr', color: 'bg-blue-500/10 text-blue-600' },
  { name: 'Kayak', domain: 'kayak.com', letter: 'K', color: 'bg-orange-500/10 text-orange-600' },
  { name: 'Vrbo', domain: 'vrbo.com', letter: 'V', color: 'bg-blue-500/10 text-blue-600' },
  { name: 'HubSpot', domain: 'hubspot.com', letter: 'HS', color: 'bg-orange-500/10 text-orange-600' },
  { name: 'Shopify', domain: 'shopify.com', letter: 'S', color: 'bg-green-500/10 text-green-600' },
  { name: 'Snapchat', domain: 'snapchat.com', letter: 'SC', color: 'bg-yellow-500/10 text-yellow-600' },
  { name: 'Reddit Ads', domain: 'reddit.com', letter: 'R', color: 'bg-orange-500/10 text-orange-600' },
  { name: 'Amazon Ads', domain: 'amazon.com', letter: 'A', color: 'bg-amber-500/10 text-amber-600' },
];
---

<section class="py-28" aria-labelledby="integrations-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 id="integrations-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
        Connects to everything. Already.
      </h2>
      <p class="reveal mt-5 text-lg text-[var(--text-tertiary)] leading-relaxed">
        One integration to rule your entire ad stack. No more tab-switching.
      </p>
    </div>

    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-3">
      {platforms.map((platform) => (
        <div class="reveal glass hover-glow flex flex-col items-center gap-2.5 p-4 rounded-xl transition-all duration-200">
          <div class="integration-logo w-12 h-12 rounded-xl flex items-center justify-center text-sm font-bold overflow-hidden bg-white shadow-sm border border-[var(--border)]">
            <img
              src={`https://logo.clearbit.com/${platform.domain}`}
              alt=""
              width="48"
              height="48"
              class="integration-logo-img w-full h-full object-contain p-1.5"
              loading="lazy"
            />
            <span class={`integration-logo-fallback absolute inset-0 flex items-center justify-center ${platform.color}`}>{platform.letter}</span>
          </div>
          <span class="text-[11px] text-[var(--text-tertiary)] font-medium text-center leading-tight">{platform.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .integration-logo {
    position: relative;
  }
  .integration-logo-img {
    position: relative;
    z-index: 1;
    /* Keep actual color logos — no grayscale or tint */
    filter: none;
  }
  .integration-logo-fallback {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  html.dark .integration-logo {
    background: var(--surface-raised) !important;
    border-color: var(--border);
  }
</style>

<script>
  document.querySelectorAll('.integration-logo-img').forEach((img) => {
    img.addEventListener('error', function () {
      this.style.display = 'none';
    });
  });
</script>
