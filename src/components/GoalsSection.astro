---
const goals = [
  { title: 'Maximize leads and conversions', desc: 'Get better quality leads and enhance conversions.' },
  { title: 'Increase online sales', desc: 'Show up where shoppers are and increase site traffic and sales.' },
  { title: 'Unify Google, Meta & OTAs', desc: 'One dashboard. Every channel. No more tab-switching.' },
  { title: 'Save time on optimization', desc: 'Let AI handle bidding and budget shifts while you sleep.' },
  { title: 'Scale without overages', desc: 'Stay in control of your budget. Adjust at any time.' },
];
---

<section class="py-16 sm:py-24 bg-[var(--surface-alt)]" aria-labelledby="goals-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <h2 id="goals-heading" class="reveal text-2xl sm:text-3xl lg:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
        Achieve all your goals in one place
      </h2>
      <a href="/features" class="reveal inline-block mt-4 link-secondary font-semibold text-sm">Learn more</a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
      {goals.map((goal) => (
        <article class="reveal rounded-xl border border-[var(--border)] bg-[var(--surface)] p-6">
          <h3 class="text-base font-bold text-[var(--text-primary)] mb-2">{goal.title}</h3>
          <p class="text-[var(--text-tertiary)] text-sm leading-relaxed">{goal.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
