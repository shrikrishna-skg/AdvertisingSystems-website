# Copy to .env and fill in. Never commit .env or real secrets.

# Google Calendar API (for /api/book-demo)
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Use "Desktop app" or "Web application" and add your redirect URI.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# One-time: run an OAuth flow with access_type=offline&prompt=consent to get a refresh token
# for the Google account that owns the calendar (e.g. shrikrishna@multisystems.ai).
# Get refresh token: node scripts/get-google-refresh-token.js (sign in as shrikrishna@multisystems.ai)
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_CALENDAR_ID=primary
