---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const breadcrumbs = [{ name: 'Privacy Policy', href: '/privacy' }];
---

<Layout
  title="Privacy Policy — AdvertisingSystems | Your Data & How We Use It"
  description="What data we collect, how we use it, and how we protect it. Your privacy and control over your information."
  breadcrumbs={breadcrumbs}
>
  <Navbar />
  <Breadcrumb items={breadcrumbs} />
  <main>
    <!-- Hero -->
    <section class="pt-36 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 mesh-gradient opacity-30"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center">
          <h1 class="reveal text-4xl sm:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Privacy <span class="text-gradient">Policy</span>
          </h1>
          <p class="reveal mt-4 text-[var(--text-tertiary)]">Last updated: March 2026</p>
          <p class="reveal mt-4 text-base font-medium text-[var(--text-secondary)] max-w-2xl mx-auto">
            In short: we use your data to run and improve the product, we don't sell it to third parties, and you can request access or deletion anytime. Details below.
          </p>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="pb-28">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">

        <article class="reveal glass rounded-2xl p-8">
          <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">1. Data We Collect</h2>
          <p class="text-[var(--text-tertiary)] leading-relaxed mb-3">Multisystems Inc. ("we," "us," or "AdvertisingSystems") collects the following categories of information:</p>
          <ul class="space-y-2 text-[var(--text-tertiary)] list-disc list-inside">
            <li><strong class="text-[var(--text-secondary)]">Account Information:</strong> Name, email address, company name, and billing details you provide during registration.</li>
            <li><strong class="text-[var(--text-secondary)]">Usage Data:</strong> Pages visited, features used, campaign configurations, and interaction logs within the platform.</li>
            <li><strong class="text-[var(--text-secondary)]">Device &amp; Technical Data:</strong> IP address, browser type, operating system, and device identifiers.</li>
            <li><strong class="text-[var(--text-secondary)]">Third-Party Data:</strong> Advertising performance metrics synced from connected platforms (Google Ads, Meta Ads, etc.).</li>
          </ul>
        </article>

        <article class="reveal glass rounded-2xl p-8">
          <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">2. How We Use Your Data</h2>
          <ul class="space-y-2 text-[var(--text-tertiary)] list-disc list-inside">
            <li>To provide, maintain, and improve the AdvertisingSystems platform.</li>
            <li>To personalize your experience and deliver AI-powered optimization recommendations.</li>
            <li>To process payments and manage your subscription.</li>
            <li>To communicate service updates, security alerts, and product announcements.</li>
            <li>To analyze aggregate usage patterns and improve platform performance.</li>
          </ul>
        </article>

        <article class="reveal glass rounded-2xl p-8">
          <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">3. Data Sharing</h2>
          <p class="text-[var(--text-tertiary)] leading-relaxed mb-3">We do not sell your personal data. We may share information with:</p>
          <ul class="space-y-2 text-[var(--text-tertiary)] list-disc list-inside">
            <li><strong class="text-[var(--text-secondary)]">Service Providers:</strong> Infrastructure partners (hosting, payment processing) who process data on our behalf under strict agreements.</li>
            <li><strong class="text-[var(--text-secondary)]">Connected Platforms:</strong> Ad networks you authorize us to connect with, solely to manage your campaigns.</li>
            <li><strong class="text-[var(--text-secondary)]">Legal Compliance:</strong> When required by law, regulation, or valid legal process.</li>
          </ul>
        </article>

        <article class="reveal glass rounded-2xl p-8">
          <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">4. Cookies &amp; Tracking</h2>
          <p class="text-[var(--text-tertiary)] leading-relaxed">
            We use essential cookies to keep you signed in and analytics cookies to understand how the platform is used. Marketing cookies are only set with your consent. For full details, see our <a href="/cookies" class="text-royal-green-600 hover:text-royal-green-500 transition-colors font-semibold">Cookie Policy</a>.
          </p>
        </article>

        <article class="reveal glass rounded-2xl p-8">
          <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">5. Your Rights</h2>
          <p class="text-[var(--text-tertiary)] leading-relaxed mb-3">Depending on your jurisdiction, you may have the right to:</p>
          <ul class="space-y-2 text-[var(--text-tertiary)] list-disc list-inside">
            <li>Access, correct, or delete your personal data.</li>
            <li>Export your data in a portable format.</li>
            <li>Withdraw consent for optional data processing.</li>
            <li>Object to or restrict certain processing activities.</li>
            <li>Lodge a complaint with your local data protection authority.</li>
          </ul>
        </article>

        <article class="reveal glass rounded-2xl p-8">
          <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">6. Contact Us</h2>
          <p class="text-[var(--text-tertiary)] leading-relaxed">
            For privacy-related inquiries, contact our Data Protection team at
            <a href="mailto:privacy@advertisingsystems.ai" class="text-royal-green-600 hover:text-royal-green-500 transition-colors font-semibold">privacy@advertisingsystems.ai</a>
            or write to: Multisystems Inc., Privacy Team, 548 Market St, Suite 35435, San Francisco, CA 94104.
          </p>
        </article>

        <div class="reveal mt-12 pt-12 border-t border-[var(--border)] text-center">
          <p class="text-[var(--text-secondary)] font-medium mb-2">General questions about the product or your account?</p>
          <a href="/faq" class="text-royal-green-600 font-semibold hover:text-royal-green-500 transition-colors">View our FAQ</a>
          <span class="text-[var(--text-muted)]"> or </span>
          <a href="/contact" class="text-royal-green-600 font-semibold hover:text-royal-green-500 transition-colors">contact us</a>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>
