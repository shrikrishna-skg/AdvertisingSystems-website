---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { integrationsFaqs } from '../data/page-faqs';

const breadcrumbs = [{ name: 'Integrations', href: '/integrations' }];

const integrationGroups = [
  {
    category: 'Ad Platforms',
    items: [
      { name: 'Google Ads', letter: 'G', color: 'text-blue-500' },
      { name: 'Meta Ads', letter: 'M', color: 'text-blue-600' },
      { name: 'Microsoft Ads', letter: 'B', color: 'text-cyan-500' },
      { name: 'TikTok Ads', letter: 'T', color: 'text-pink-500' },
    ],
  },
  {
    category: 'Online Travel Agencies',
    items: [
      { name: 'Booking.com', letter: 'B', color: 'text-blue-700' },
      { name: 'Expedia', letter: 'E', color: 'text-yellow-500' },
      { name: 'Airbnb', letter: 'A', color: 'text-rose-500' },
      { name: 'TripAdvisor', letter: 'T', color: 'text-green-600' },
    ],
  },
  {
    category: 'Analytics',
    items: [
      { name: 'Google Analytics', letter: 'GA', color: 'text-orange-500' },
      { name: 'Adobe Analytics', letter: 'AA', color: 'text-red-600' },
    ],
  },
  {
    category: 'CRM',
    items: [
      { name: 'Salesforce', letter: 'SF', color: 'text-sky-500' },
      { name: 'HubSpot', letter: 'HS', color: 'text-orange-600' },
    ],
  },
];
---

<Layout
  title="Integrations — AdvertisingSystems | Connect Your Ad Platforms & Tools"
  description="Connect Google Ads, Meta, OTAs, analytics, and CRMs in one place. See which platforms we support and how to connect your stack."
  breadcrumbs={breadcrumbs}
>
  <Navbar />
  <Breadcrumb items={breadcrumbs} />
  <main>
    <!-- Hero -->
    <section class="pt-36 pb-20 relative overflow-hidden" aria-labelledby="integrations-heading">
      <div class="absolute inset-0 mesh-gradient opacity-30"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center">
          <h1 id="integrations-heading" class="reveal text-4xl sm:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            <span class="text-[var(--text-primary)]">Powerful Integrations</span>
          </h1>
          <p class="reveal mt-5 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
            Connect your entire advertising stack. AdvertisingSystems works with the platforms you already use.
          </p>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Why one platform -->
    <section class="py-20" aria-labelledby="why-one-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="why-one-heading" class="reveal text-2xl sm:text-3xl font-bold text-[var(--text-primary)] tracking-[-0.02em]">
          One login. <span class="text-[var(--text-primary)]">One dashboard.</span>
        </h2>
        <p class="reveal mt-4 text-lg font-medium text-[var(--text-tertiary)] leading-relaxed">
          Stop switching tabs. Connect Google Ads, Meta, and OTAs in one place — one AI optimizes across all of them, and you see unified reporting and attribution instead of scattered spreadsheets.
        </p>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- How connecting works -->
    <section class="py-20" aria-labelledby="how-connect-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="how-connect-heading" class="reveal text-2xl sm:text-3xl font-bold text-[var(--text-primary)] tracking-[-0.02em]">
          Connect in <span class="text-[var(--text-primary)]">minutes.</span>
        </h2>
        <p class="reveal mt-4 text-lg font-medium text-[var(--text-tertiary)] leading-relaxed">
          OAuth with Google, Meta, and OTAs — no CSV imports. Your data syncs every 15 minutes. No IT ticket, no custom dev work. Most teams are live in under 15 minutes.
        </p>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Integration Groups -->
    <section class="pb-28">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
        {integrationGroups.map((group) => (
          <div>
            <h2 class="reveal text-xl font-bold text-[var(--text-primary)] mb-6">{group.category}</h2>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              {group.items.map((item) => (
                <div class="reveal glass rounded-2xl p-6 text-center hover:border-[var(--border)] transition-all duration-300 hover-glow">
                  <div class="w-14 h-14 rounded-xl bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mx-auto mb-4">
                    <span class={`text-lg font-bold ${item.color}`}>{item.letter}</span>
                  </div>
                  <p class="text-sm font-semibold text-[var(--text-primary)]">{item.name}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Don't see your platform? + API -->
      <div class="reveal max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mt-20">
        <div class="glass rounded-2xl p-10 text-center">
          <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-3">Don't see your platform?</h2>
          <p class="text-[var(--text-tertiary)] font-medium mb-4 max-w-lg mx-auto">
            We're always adding new integrations. Professional and Enterprise plans include REST API access for custom connections (CRM, BI, internal tools).
          </p>
          <p class="text-sm text-[var(--text-muted)] font-medium mb-6 max-w-lg mx-auto">
            Need something specific? Tell us what you use — we'll prioritize it or help you build a custom connection.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/signup" class="inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold px-6 py-3 rounded-lg hover:bg-royal-green-600 transition-colors">
              Start Free Trial
            </a>
            <a href="/contact" class="inline-flex items-center justify-center gap-2 text-[var(--text-tertiary)] border border-[var(--border)] font-semibold px-6 py-3 rounded-lg hover:border-[var(--color-link)] hover:text-[var(--color-link)] transition-colors">
              Request Integration
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={integrationsFaqs} name="integrations-faq" />

    <div class="section-line"></div>

    <!-- Bottom CTA -->
    <section class="relative py-32 overflow-hidden" aria-labelledby="integrations-cta-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>
      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="integrations-cta-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Ready to <span class="text-[var(--text-primary)]">connect your stack?</span>
        </h2>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          One platform for Google, Meta, and OTAs. Start your free trial or book a demo to see it in action.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/signup" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg ">
            Start free trial
          </a>
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 text-[var(--text-secondary)] font-semibold text-base px-8 py-3.5 rounded-lg border border-[var(--border)] hover:border-[var(--color-link)] hover:text-[var(--color-link)] transition-colors">
            Book a demo
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
