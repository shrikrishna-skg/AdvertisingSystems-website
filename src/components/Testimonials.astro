---
import { testimonials } from '../data/testimonials';
---

<section class="py-28" aria-labelledby="testimonials-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 id="testimonials-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
        Real results.
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((testimonial) => (
        <article class="reveal glass hover-glow rounded-2xl p-8 transition-all duration-300">
          <div class="flex gap-0.5 mb-5" aria-label={`${testimonial.stars} out of 5 stars`}>
            {Array.from({ length: testimonial.stars }).map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <blockquote>
            <span class="text-2xl text-[var(--text-tertiary)] font-serif leading-none">&ldquo;</span>
            <p class="text-[var(--text-tertiary)] leading-relaxed">{testimonial.quote}</p>
          </blockquote>

          <footer class="mt-6">
            <cite class="not-italic">
              <div class="text-sm font-medium text-[var(--text-primary)]">{testimonial.name}</div>
              <div class="text-xs text-[var(--text-muted)] mt-0.5">{testimonial.role}</div>
            </cite>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
