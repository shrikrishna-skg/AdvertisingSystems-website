---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { pricingPlans } from '../data/pricing';

const breadcrumbs = [{ name: 'Pricing Intelligence', href: '/pricing-intelligence' }];

const whyClarity = [
  {
    title: 'No hidden fees',
    body: 'One price covers your plan. We don’t charge per click, per campaign, or per integration. What you see is what you pay.',
  },
  {
    title: 'Predictable spend',
    body: 'Scale your ad accounts without surprise line items. Upgrade when you’re ready; we don’t lock you into long-term contracts.',
  },
  {
    title: 'Full transparency',
    body: 'Every plan includes the same core: AI optimization, real-time analytics, and support. No feature paywalls inside your tier.',
  },
];

const includedInAll = [
  'Unlimited campaigns across Google, Meta, and OTAs',
  'AI bid and budget optimization',
  'Real-time dashboards and revenue attribution',
  'Email and chat support',
  '14-day free trial — no credit card required',
];

const pricingFaqs = [
  {
    question: 'Are there any hidden fees?',
    answer: 'No. Your subscription is all-in. We don’t charge per click, per campaign, or per integration. Setup is included; there are no onboarding or implementation fees.',
  },
  {
    question: 'Can I change plans later?',
    answer: 'Yes. You can upgrade or downgrade anytime. Changes take effect at the start of your next billing cycle. We’ll prorate if you upgrade mid-cycle.',
  },
  {
    question: 'What if I need more than 10 ad accounts?',
    answer: 'Enterprise is for unlimited ad accounts and custom needs. Contact us for a tailored quote and dedicated support.',
  },
  {
    question: 'Is there a long-term contract?',
    answer: 'No. All plans are month-to-month. Cancel anytime. We believe you’ll stay because the product earns its keep, not because you’re locked in.',
  },
  {
    question: 'What’s included in the free trial?',
    answer: 'Full access to your chosen plan for 14 days. No credit card required. You can connect your ad accounts, run the AI, and see real results before paying.',
  },
];
---

<Layout
  breadcrumbs={[{ name: 'Home', href: '/' }, ...breadcrumbs]}
  title="Pricing Intelligence — AdvertisingSystems | Simple, Transparent Pricing"
  description="One price. No hidden fees, no per-click charges. See what you get in every plan and how our pricing scales with your growth."
>
  <Navbar />
  <Breadcrumb items={[{ name: 'Home', href: '/' }, ...breadcrumbs]} />
  <main>
    <!-- Hero: one promise -->
    <section class="relative pt-40 pb-20 sm:pt-48 sm:pb-28 overflow-hidden" aria-labelledby="pricing-intel-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 id="pricing-intel-heading" class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Pricing that <span class="text-[var(--text-primary)]">scales with you.</span>
        </h1>
        <p class="reveal mt-6 text-xl sm:text-2xl font-medium text-[var(--text-secondary)] max-w-2xl mx-auto">
          No hidden fees. No per-click tricks. One price for everything.
        </p>
        <div class="reveal mt-10">
          <a href="#plans" class="inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg ">
            See plans
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Why pricing clarity matters -->
    <section class="py-28" aria-labelledby="why-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="why-heading" class="reveal text-center text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          Why we keep it <span class="text-[var(--text-primary)]">simple</span>
        </h2>
        <p class="reveal mt-4 text-center text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          You should know exactly what you’re paying for. No surprises at the end of the month.
        </p>

        <div class="reveal mt-16 grid md:grid-cols-3 gap-8">
          {whyClarity.map((item) => (
            <div class="glass rounded-2xl p-8 border-t-4 border-[var(--border)]">
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-3">{item.title}</h3>
              <p class="text-[var(--text-tertiary)] font-medium leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- What you get in every plan -->
    <section class="py-28" aria-labelledby="included-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="included-heading" class="reveal text-center text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          What you get in <span class="text-[var(--text-primary)]">every plan</span>
        </h2>
        <ul class="reveal mt-10 space-y-4" role="list">
          {includedInAll.map((item) => (
            <li class="flex items-start gap-3 text-[var(--text-secondary)] font-medium">
              <span class="mt-1 w-5 h-5 rounded-full bg-[var(--surface-alt)] flex items-center justify-center shrink-0" aria-hidden="true">
                <svg class="w-3 h-3 text-[var(--text-tertiary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Plans (anchoring: Good / Better / Best) -->
    <section id="plans" class="py-28" aria-labelledby="plans-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="plans-heading" class="reveal text-center text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          Plans that <span class="text-[var(--text-primary)]">scale</span>
        </h2>
        <p class="reveal mt-4 text-center text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          Start small, grow when you’re ready. No long-term contract.
        </p>

        <div class="reveal mt-16 grid md:grid-cols-3 gap-6 lg:gap-8 max-w-4xl mx-auto items-start">
          {pricingPlans.map((plan) => (
            <article class={`relative glass rounded-2xl p-8 transition-all duration-300 overflow-visible ${
              plan.highlighted ? 'border-[var(--border)] shadow-lg' : ''
            } ${plan.badge ? 'pt-10' : ''}`}>
              {plan.highlighted && (
                <span class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--text-tertiary)] to-[var(--text-primary)] rounded-t-2xl" aria-hidden="true"></span>
              )}
              {plan.badge && (
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2">
                  <span class="bg-[var(--text-primary)] text-white text-xs font-semibold px-3 py-1.5 rounded-full whitespace-nowrap">{plan.badge}</span>
                </div>
              )}

              <div class="text-center min-h-[4.5rem] flex flex-col justify-center">
                <h3 class="text-lg font-bold text-[var(--text-primary)]">{plan.name}</h3>
                <div class="mt-4 flex items-baseline justify-center gap-1 pb-0.5">
                  <span class={`text-4xl font-bold tracking-[-0.03em] leading-tight ${plan.highlighted ? 'text-[var(--text-primary)]' : 'text-[var(--text-primary)]'}`}>{plan.price}</span>
                  {plan.period && <span class="text-[var(--text-muted)] text-sm font-medium">{plan.period}</span>}
                </div>
                <p class="mt-2 text-sm font-medium text-[var(--text-tertiary)]">{plan.description}</p>
              </div>

              <a
                href={plan.cta.href}
                class={`mt-8 block w-full text-center text-sm font-semibold py-3 rounded-lg transition-colors ${
                  plan.highlighted
                    ? 'bg-royal-green-500 text-white hover:bg-royal-green-600'
                    : 'btn-secondary'
                }`}
              >
                {plan.cta.text}
              </a>
            </article>
          ))}
        </div>

        <p class="reveal text-center mt-10 text-sm font-medium text-[var(--text-muted)]">
          All plans include unlimited campaigns, AI optimization, and real-time analytics.
        </p>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Your investment, your return (ROI framing) -->
    <section class="py-28" aria-labelledby="investment-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="investment-heading" class="reveal text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          One platform. One price. <span class="text-[var(--text-primary)]">Predictable.</span>
        </h2>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] leading-relaxed">
          Teams running Google, Meta, and OTA ads use AdvertisingSystems to cut wasted spend and push budget to what converts. On average, 4.2x ROAS improvement and 38% lower CPA in the first 90 days. Your subscription pays for itself when the AI finds the inefficiencies you’ve been missing.
        </p>
        <p class="reveal mt-4 text-sm font-medium text-[var(--text-muted)]">
          Powering $5.2B+ in ad spend across the U.S. — by Multisystems.
        </p>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Trust: trial, no CC, cancel -->
    <section class="py-28" aria-labelledby="trust-heading">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="trust-heading" class="reveal text-2xl sm:text-3xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          Try it risk-free
        </h2>
        <ul class="reveal mt-8 space-y-3 text-[var(--text-secondary)] font-medium" role="list">
          <li class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-[var(--text-primary)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            14-day free trial
          </li>
          <li class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-[var(--text-primary)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            No credit card required
          </li>
          <li class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-[var(--text-primary)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Cancel anytime
          </li>
        </ul>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg ">
            Book a demo
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/signup" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 btn-secondary font-semibold text-base px-8 py-3.5 rounded-lg">
            Start free trial
          </a>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- FAQ: pricing objections -->
    <section class="py-28" aria-labelledby="faq-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="faq-heading" class="reveal text-center text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          Pricing <span class="text-[var(--text-primary)]">questions</span>
        </h2>

        <div class="reveal mt-16 space-y-3">
          {pricingFaqs.map((faq) => (
            <details class="group glass rounded-xl hover:border-royal-blue-500/20 transition-colors" name="pricing-faq">
              <summary class="flex items-center justify-between cursor-pointer p-5 sm:p-6 list-none [&::-webkit-details-marker]:hidden">
                <h3 class="text-base sm:text-lg font-semibold text-[var(--text-primary)] pr-4">{faq.question}</h3>
                <svg class="w-5 h-5 text-[var(--text-muted)] shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 sm:px-6 pb-5 sm:pb-6">
                <p class="text-[var(--text-tertiary)] font-medium leading-relaxed">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <div class="reveal text-center mt-12">
          <p class="text-[var(--text-muted)] font-medium">Still have questions?</p>
          <a href="/contact" class="link-secondary font-semibold">Contact us</a>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Final CTA -->
    <section class="relative py-32 overflow-hidden" aria-labelledby="final-cta-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="final-cta-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Ready for <span class="text-[var(--text-primary)]">predictable pricing?</span>
        </h2>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          See plans, start a free trial, or book a demo. No hidden fees — ever.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg ">
            Book your demo
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/#pricing" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 btn-secondary font-semibold text-base px-8 py-3.5 rounded-lg">
            View pricing on homepage
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
