---
import { features } from '../data/features';
---

<section id="features" class="py-16 sm:py-24 lg:py-32" aria-labelledby="features-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 lg:mb-24">
      <h2 id="features-heading" class="reveal text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-[56px] font-bold text-[var(--text-primary)] tracking-[-0.03em] break-words">
        One platform. <span class="text-gradient">Total control.</span>
      </h2>
      <p class="reveal mt-5 text-lg text-[var(--text-tertiary)] leading-relaxed">
        AdvertisingSystems replaces your scattered ad tools with a single AI-powered command center.
      </p>
    </div>

    <div class="flex flex-col gap-16 sm:gap-24 lg:gap-32">
      {features.map((feature, index) => (
        <article class={`reveal flex flex-col ${index % 2 === 1 ? 'lg:flex-row-reverse' : 'lg:flex-row'} gap-12 lg:gap-20 items-center`}>
          <!-- Text side -->
          <div class="flex-1 max-w-lg">
            <div class="w-12 h-12 rounded-full bg-royal-green-500/10 flex items-center justify-center mb-6">
              {feature.icon === 'layout-dashboard' && (
                <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z" />
                </svg>
              )}
              {feature.icon === 'sparkles' && (
                <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                </svg>
              )}
              {feature.icon === 'chart-bar' && (
                <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
              )}
            </div>

            <h3 class="text-2xl font-bold text-[var(--text-primary)] mb-2 tracking-[-0.02em]">{feature.title}</h3>
            <p class="text-[var(--text-tertiary)] font-medium mb-6">{feature.subtitle}</p>

            <ul class="space-y-3 mb-6" role="list">
              {feature.quotes.map((quote) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-royal-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[var(--text-tertiary)]">"{quote}"</span>
                </li>
              ))}
            </ul>

            <a href={feature.link.href} class="inline-flex items-center gap-1.5 link-secondary font-semibold">
              {feature.link.text}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>

            <div class="flex flex-wrap gap-2 mt-5">
              {feature.tags.map((tag) => (
                <span class="glass text-xs font-medium text-[var(--text-tertiary)] px-3 py-1.5 rounded-full">{tag}</span>
              ))}
            </div>
          </div>

          <!-- Mockup side -->
          <div class="flex-1 max-w-xl w-full">
            <figure class="glass rounded-2xl overflow-hidden shadow-xl">
              <!-- Browser chrome -->
              <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--browser-border)] bg-[var(--browser-chrome-bg)]">
                <div class="flex gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
                </div>
                <div class="flex-1 ml-2">
                  <div class="bg-[var(--browser-url-bg)] rounded-md px-3 py-1 text-xs text-[var(--browser-url-text)] max-w-xs">{feature.mockup.url}</div>
                </div>
              </div>

              <!-- Mockup content -->
              <div class="p-6 min-h-[280px] bg-[var(--surface-alt)]">
                {feature.mockup.type === 'campaigns' && (
                  <div>
                    <div class="flex items-center justify-between mb-4">
                      <div class="flex gap-2">
                        <span class="text-xs font-medium bg-royal-blue-500/15 text-royal-blue-600 px-2.5 py-1 rounded">All</span>
                        <span class="text-xs font-medium glass text-[var(--text-tertiary)] px-2.5 py-1 rounded">Google</span>
                        <span class="text-xs font-medium glass text-[var(--text-tertiary)] px-2.5 py-1 rounded">Meta</span>
                        <span class="text-xs font-medium glass text-[var(--text-tertiary)] px-2.5 py-1 rounded">OTA</span>
                      </div>
                    </div>
                    <div class="space-y-3">
                      <div class="flex items-center justify-between glass rounded-lg p-3">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 bg-blue-500/10 rounded-lg flex items-center justify-center text-xs font-bold text-blue-500">G</div>
                          <div><div class="text-sm font-medium text-[var(--text-primary)]">Brand Search - Downtown</div><div class="text-xs text-[var(--text-muted)]">Google Ads &middot; Active</div></div>
                        </div>
                        <div class="text-right"><div class="text-sm font-semibold text-royal-green-600">5.2x ROAS</div><div class="text-xs text-[var(--text-muted)]">$1,240 spend</div></div>
                      </div>
                      <div class="flex items-center justify-between glass rounded-lg p-3">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 bg-indigo-500/10 rounded-lg flex items-center justify-center text-xs font-bold text-indigo-500">M</div>
                          <div><div class="text-sm font-medium text-[var(--text-primary)]">Summer Promo - Instagram</div><div class="text-xs text-[var(--text-muted)]">Meta Ads &middot; Active</div></div>
                        </div>
                        <div class="text-right"><div class="text-sm font-semibold text-royal-green-600">3.8x ROAS</div><div class="text-xs text-[var(--text-muted)]">$890 spend</div></div>
                      </div>
                      <div class="flex items-center justify-between glass rounded-lg p-3">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 bg-amber-500/10 rounded-lg flex items-center justify-center text-xs font-bold text-amber-500">B</div>
                          <div><div class="text-sm font-medium text-[var(--text-primary)]">Sponsored Listing - Booking</div><div class="text-xs text-[var(--text-muted)]">Booking.com &middot; Active</div></div>
                        </div>
                        <div class="text-right"><div class="text-sm font-semibold text-royal-green-600">6.1x ROAS</div><div class="text-xs text-[var(--text-muted)]">$560 spend</div></div>
                      </div>
                    </div>
                  </div>
                )}
                {feature.mockup.type === 'optimization' && (
                  <div>
                    <div class="flex items-center justify-between mb-4">
                      <div class="text-sm font-semibold text-[var(--text-primary)]">AI Optimization Engine</div>
                      <span class="text-xs font-medium bg-royal-green-500/15 text-royal-green-600 px-2.5 py-1 rounded-full flex items-center gap-1">
                        <span class="w-1.5 h-1.5 bg-royal-green-500 rounded-full animate-pulse"></span>
                        Live
                      </span>
                    </div>
                    <div class="space-y-3">
                      <div class="glass rounded-lg p-3">
                        <div class="flex items-center justify-between mb-2">
                          <span class="text-xs font-medium text-[var(--text-tertiary)]">Bid Adjustment</span>
                          <span class="text-xs font-semibold text-royal-green-600">+18% CTR</span>
                        </div>
                        <div class="w-full bg-[var(--progress-track)] rounded-full h-2"><div class="bg-royal-green-500 h-2 rounded-full" style="width: 72%"></div></div>
                      </div>
                      <div class="glass rounded-lg p-3">
                        <div class="flex items-center justify-between mb-2">
                          <span class="text-xs font-medium text-[var(--text-tertiary)]">Budget Reallocation</span>
                          <span class="text-xs font-semibold text-royal-green-600">-$420 waste</span>
                        </div>
                        <div class="w-full bg-[var(--progress-track)] rounded-full h-2"><div class="bg-royal-green-600 h-2 rounded-full" style="width: 58%"></div></div>
                      </div>
                      <div class="bg-royal-blue-500/10 rounded-lg p-3 border border-royal-blue-500/20">
                        <div class="flex items-center gap-2 mb-1">
                          <svg class="w-4 h-4 text-royal-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" /></svg>
                          <span class="text-xs font-semibold text-royal-blue-600">AI Insight</span>
                        </div>
                        <p class="text-xs text-royal-blue-700/80">"Weekend bids are 40% higher than weekday with similar conversion rates. Recommend reducing weekend bids by 25%."</p>
                      </div>
                    </div>
                  </div>
                )}
                {feature.mockup.type === 'analytics' && (
                  <div>
                    <div class="flex items-center justify-between mb-4">
                      <div class="text-sm font-semibold text-[var(--text-primary)]">Performance Dashboard</div>
                      <span class="text-xs text-[var(--text-muted)]">Last 30 days</span>
                    </div>
                    <div class="grid grid-cols-3 gap-3 mb-4">
                      <div class="glass rounded-lg p-3 text-center">
                        <div class="text-lg font-bold text-royal-green-600">4.2x</div>
                        <div class="text-xs text-[var(--text-muted)]">ROAS</div>
                      </div>
                      <div class="glass rounded-lg p-3 text-center">
                        <div class="text-lg font-bold text-[var(--text-primary)]">$12.40</div>
                        <div class="text-xs text-[var(--text-muted)]">CPA</div>
                      </div>
                      <div class="glass rounded-lg p-3 text-center">
                        <div class="text-lg font-bold text-[var(--text-primary)]">2,847</div>
                        <div class="text-xs text-[var(--text-muted)]">Conversions</div>
                      </div>
                    </div>
                    <div class="glass rounded-lg p-4">
                      <div class="flex items-end justify-between h-24 gap-1">
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 45%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 55%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 48%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 65%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 78%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 70%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 85%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 92%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 88%"></div>
                        <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to-strong)]" style="height: 100%"></div>
                      </div>
                      <div class="flex justify-between mt-2 text-[10px] text-[var(--text-muted)]">
                        <span>Week 1</span><span>Week 2</span><span>Week 3</span><span>Week 4</span>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            </figure>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
