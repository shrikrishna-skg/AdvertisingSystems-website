---
const painPoints = [
  {
    icon: 'scatter',
    title: 'Fragmented Campaigns',
    description: "Five platforms, five dashboards, zero visibility. You're flying blind across Google, Meta, and OTAs with no single source of truth.",
  },
  {
    icon: 'money',
    title: 'Budget Black Holes',
    description: "Money disappears into underperforming campaigns. By the time you catch it, thousands are gone — with nothing to show for it.",
  },
  {
    icon: 'clock',
    title: 'Manual Optimization Hell',
    description: "Adjusting bids, shifting budgets, testing audiences — all by hand, all day. There's never enough time, and the platforms keep changing.",
  },
];
---

<section class="py-28" aria-labelledby="pain-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 id="pain-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
        Sound familiar?
      </h2>
      <p class="reveal mt-5 text-lg text-[var(--text-tertiary)] leading-relaxed">
        Every marketer hits the same wall. Here's where most ad budgets go to die.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {painPoints.map((point) => (
        <article class="reveal glass hover-glow rounded-2xl p-8 transition-all duration-300">
          <div class="w-12 h-12 rounded-full bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mb-6">
            {point.icon === 'scatter' && (
              <svg class="w-6 h-6 text-[var(--text-tertiary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
              </svg>
            )}
            {point.icon === 'money' && (
              <svg class="w-6 h-6 text-[var(--text-tertiary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
              </svg>
            )}
            {point.icon === 'clock' && (
              <svg class="w-6 h-6 text-[var(--text-tertiary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
          </div>
          <h3 class="text-xl font-bold text-[var(--text-primary)] mb-3">{point.title}</h3>
          <p class="text-[var(--text-tertiary)] leading-relaxed">{point.description}</p>
        </article>
      ))}
    </div>

    <p class="reveal text-center mt-14 text-xl font-semibold text-[var(--text-primary)]">There's a smarter way.</p>
  </div>
</section>
