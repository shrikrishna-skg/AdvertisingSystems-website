---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { blogFaqs } from '../data/page-faqs';

const breadcrumbs = [{ name: 'Blog', href: '/blog' }];

const posts = [
  {
    category: 'Product Updates',
    title: 'Introducing AI Budget Allocator 2.0: Smarter Cross-Channel Spending',
    excerpt: 'Our latest release brings real-time budget reallocation across Google, Meta, and OTA campaigns — driven by reinforcement learning that adapts every 15 minutes.',
    date: 'Mar 8, 2026',
    readTime: '4 min read',
    color: 'royal-green',
  },
  {
    category: 'Advertising Tips',
    title: 'How to Cut CPA by 40% Without Reducing Ad Spend',
    excerpt: 'Most advertisers chase cheaper clicks. The real lever is audience precision. Here are 5 proven strategies our top-performing accounts use to slash acquisition costs.',
    date: 'Mar 1, 2026',
    readTime: '7 min read',
    color: 'blue',
  },
  {
    category: 'Case Studies',
    title: 'How a Boutique Hotel Chain Achieved 5.8x ROAS in 60 Days',
    excerpt: 'Mediterranean Escapes went from scattered OTA campaigns to a unified AI-optimized strategy — and saw revenue per room night increase 230%.',
    date: 'Feb 22, 2026',
    readTime: '6 min read',
    color: 'violet',
  },
  {
    category: 'Industry Trends',
    title: 'The Death of Manual Bidding: What 2026 Means for PPC Managers',
    excerpt: 'Automation isn\'t replacing PPC professionals — it\'s elevating them. A look at how the role is shifting from bid management to strategic oversight.',
    date: 'Feb 14, 2026',
    readTime: '5 min read',
    color: 'amber',
  },
  {
    category: 'Advertising Tips',
    title: 'Meta Ads + Google Ads: The Cross-Channel Playbook That Actually Works',
    excerpt: 'Running both platforms in silos? You\'re leaving money on the table. Learn how unified attribution reveals the full customer journey and boosts ROAS.',
    date: 'Feb 7, 2026',
    readTime: '8 min read',
    color: 'blue',
  },
  {
    category: 'Product Updates',
    title: 'New Integration: TikTok Ads Now Live in AdvertisingSystems',
    excerpt: 'Manage TikTok campaigns alongside Google, Meta, and OTAs from a single dashboard. Full bidding, analytics, and AI optimization support included.',
    date: 'Jan 30, 2026',
    readTime: '3 min read',
    color: 'royal-green',
  },
];

const categoryColor = (color: string) => {
  switch (color) {
    case 'royal-green': return 'bg-royal-green-500/10 text-royal-green-600';
    case 'blue': return 'bg-blue-500/10 text-blue-600';
    case 'violet': return 'bg-violet-500/10 text-violet-600';
    case 'amber': return 'bg-amber-500/10 text-amber-600';
    default: return 'bg-royal-green-500/10 text-royal-green-600';
  }
};

const categories = ['All', 'Product Updates', 'Advertising Tips', 'Case Studies', 'Industry Trends'];
const featuredPost = posts[0];
const otherPosts = posts.slice(1);
---

<Layout
  title="Blog — Insights & Resources | AdvertisingSystems"
  description="Advertising tips, product updates, case studies, and industry trends from the AdvertisingSystems team."
  breadcrumbs={breadcrumbs}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'AdvertisingSystems Blog',
    url: 'https://advertisingsystems.ai/blog',
    description: 'Insights, strategies, and updates on AI-powered advertising management.',
    publisher: {
      '@type': 'Organization',
      name: 'AdvertisingSystems'
    }
  }}
>
  <Navbar />
  <Breadcrumb items={breadcrumbs} />
  <main>
    <!-- Hero -->
    <section class="relative pt-40 pb-20 sm:pt-48 sm:pb-28 overflow-hidden" aria-labelledby="blog-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="reveal inline-flex items-center gap-2 glass rounded-full px-5 py-2 mb-8">
          <span class="w-2 h-2 bg-royal-green-400 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-[var(--text-tertiary)]">From the AdvertisingSystems Team</span>
        </div>

        <h1 id="blog-heading" class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Insights &amp; <span class="text-gradient">Resources</span>
        </h1>
        <p class="reveal mt-6 text-lg sm:text-xl text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          Advertising tips, product updates, case studies, and industry trends to help you get more from every ad dollar.
        </p>
      </div>
    </section>

    <!-- Featured post -->
    <section class="py-12" aria-label="Featured post">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="reveal text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-6">Featured</h2>
        <a href="#" class="reveal group block glass hover-glow rounded-2xl p-8 sm:p-10 border-2 border-royal-green-500/20 transition-all duration-300">
          <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full mb-4 ${categoryColor(featuredPost.color)}`}>
            {featuredPost.category}
          </span>
          <h2 class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)] mb-4 group-hover:text-royal-green-600 transition-colors leading-tight">
            {featuredPost.title}
          </h2>
          <p class="text-[var(--text-tertiary)] font-medium leading-relaxed max-w-3xl mb-6">
            {featuredPost.excerpt}
          </p>
          <div class="flex items-center gap-3 text-sm text-[var(--text-muted)] font-medium">
            <time>{featuredPost.date}</time>
            <span aria-hidden="true">&middot;</span>
            <span>{featuredPost.readTime}</span>
            <svg class="w-5 h-5 ml-auto text-[var(--text-muted)] group-hover:text-royal-green-500 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Category filter + Blog Post Grid -->
    <section class="py-20" aria-label="Blog posts">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap gap-2 mb-10" role="tablist" aria-label="Filter by category">
          {categories.map((cat) => (
            <button
              type="button"
              class="blog-filter px-4 py-2 rounded-full text-sm font-semibold transition-colors data-[active]:bg-royal-green-500/15 data-[active]:text-royal-green-600 data-[active]:border-royal-green-500/30 border border-transparent data-[active]:border text-[var(--text-tertiary)] hover:bg-royal-green-500/10 hover:text-royal-green-600 border-[var(--border)]"
              data-category={cat === 'All' ? '*' : cat}
              data-active={cat === 'All'}
            >
              {cat}
            </button>
          ))}
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
          {otherPosts.map((post) => (
            <a href="#" class="blog-card reveal group glass hover-glow rounded-2xl p-8 transition-all duration-300 block" data-category={post.category}>
              <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full mb-4 ${categoryColor(post.color)}`}>
                {post.category}
              </span>
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-3 group-hover:text-royal-green-600 transition-colors leading-snug">
                {post.title}
              </h3>
              <p class="text-sm text-[var(--text-tertiary)] leading-relaxed mb-6">
                {post.excerpt}
              </p>
              <div class="flex items-center justify-between mt-auto">
                <div class="flex items-center gap-3 text-xs text-[var(--text-muted)] font-medium">
                  <time>{post.date}</time>
                  <span aria-hidden="true">&middot;</span>
                  <span>{post.readTime}</span>
                </div>
                <svg class="w-5 h-5 text-[var(--text-muted)] group-hover:text-royal-green-500 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <script>
      document.querySelectorAll('.blog-filter').forEach((btn) => {
        btn.addEventListener('click', () => {
          const category = btn.getAttribute('data-category');
          document.querySelectorAll('.blog-filter').forEach((b) => b.removeAttribute('data-active'));
          btn.setAttribute('data-active', '');
          document.querySelectorAll('.blog-card').forEach((card) => {
            const cardCat = card.getAttribute('data-category');
            const show = category === '*' || cardCat === category;
            (card as HTMLElement).style.display = show ? '' : 'none';
          });
        });
      });
    </script>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={blogFaqs} name="blog-faq" />

    <div class="section-line"></div>

    <!-- Subscribe CTA -->
    <section class="relative py-32 overflow-hidden" aria-labelledby="blog-cta-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="blog-cta-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Stay ahead of the <span class="text-gradient">curve.</span>
        </h2>
        <p class="reveal mt-6 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
          Get the latest advertising insights, product updates, and optimization strategies delivered to your inbox.
        </p>

        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 max-w-md mx-auto">
          <input
            type="email"
            placeholder="you@company.com"
            aria-label="Email address"
            class="w-full px-5 py-3.5 rounded-lg bg-[var(--surface-alt)] border border-[var(--border)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-royal-green-500/50 transition-colors"
          />
          <button
            type="button"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20 whitespace-nowrap"
          >
            Subscribe
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </button>
        </div>

        <p class="reveal mt-6 text-sm font-medium text-[var(--text-muted)]">Weekly digest. No spam. Unsubscribe anytime.</p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
