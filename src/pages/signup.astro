---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { signupFaqs } from '../data/page-faqs';

const breadcrumbs = [{ name: 'Sign Up', href: '/signup' }];

const whatYouGet = [
  'Full access to all 5 modules — Campaign Intelligence, AI Optimization, Analytics, Automation, Budget Allocator',
  'Connect Google Ads, Meta Ads, and OTAs in one dashboard',
  '14-day free trial — no credit card required',
  'Cancel anytime. No long-term contract.',
];
---

<Layout
  title="Start Your Free Trial — AdvertisingSystems | No Credit Card Required"
  description="Create your account and get full access to AdvertisingSystems for 14 days. Unify Google, Meta, and OTA campaigns with AI optimization — no credit card required."
  breadcrumbs={breadcrumbs}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Sign Up — AdvertisingSystems',
    url: 'https://advertisingsystems.ai/signup',
    potentialAction: {
      '@type': 'CreateAction',
      name: 'Start Free Trial',
      target: 'https://advertisingsystems.ai/signup'
    }
  }}
>
  <Navbar />
  <Breadcrumb items={breadcrumbs} />
  <main>
    <section class="pt-36 pb-28 relative overflow-hidden" aria-labelledby="signup-heading">
      <div class="absolute inset-0 mesh-gradient opacity-30"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center mb-8">
          <h1 id="signup-heading" class="reveal text-4xl sm:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Start your <span class="text-[var(--text-primary)]">free trial</span>
          </h1>
          <p class="reveal mt-4 text-lg font-medium text-[var(--text-tertiary)]">
            Get full access to AdvertisingSystems for 14 days.
          </p>
          <p class="reveal mt-2 text-sm font-medium text-[var(--text-muted)]">
            Join 2,000+ businesses. $5.2B+ in ad spend managed on our platform.
          </p>
        </div>

        <!-- What you get -->
        <div class="reveal max-w-lg mx-auto mb-10">
          <h2 class="sr-only">What you get</h2>
          <ul class="glass rounded-2xl p-6 space-y-3" role="list">
            {whatYouGet.map((item) => (
              <li class="flex items-start gap-3 text-sm font-medium text-[var(--text-secondary)]">
                <span class="mt-0.5 w-5 h-5 rounded-full bg-[var(--surface-alt)] flex items-center justify-center shrink-0" aria-hidden="true">
                  <svg class="w-3 h-3 text-[var(--color-link)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="max-w-lg mx-auto">
        <form class="reveal glass rounded-2xl p-8 space-y-5">
          <div>
            <label for="name" class="block text-sm font-semibold text-[var(--text-secondary)] mb-1.5">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full px-4 py-3 rounded-lg bg-[var(--surface-alt)] border border-[var(--border)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--color-link)] focus:ring-1 focus:ring-[var(--color-link)] transition-colors"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-[var(--text-secondary)] mb-1.5">Work Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jane@company.com"
              class="w-full px-4 py-3 rounded-lg bg-[var(--surface-alt)] border border-[var(--border)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--color-link)] focus:ring-1 focus:ring-[var(--color-link)] transition-colors"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-semibold text-[var(--text-secondary)] mb-1.5">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              placeholder="8+ characters"
              minlength="8"
              class="w-full px-4 py-3 rounded-lg bg-[var(--surface-alt)] border border-[var(--border)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--color-link)] focus:ring-1 focus:ring-[var(--color-link)] transition-colors"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-semibold text-[var(--text-secondary)] mb-1.5">Company</label>
            <input
              type="text"
              id="company"
              name="company"
              required
              placeholder="Acme Corp"
              class="w-full px-4 py-3 rounded-lg bg-[var(--surface-alt)] border border-[var(--border)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--color-link)] focus:ring-1 focus:ring-[var(--color-link)] transition-colors"
            />
          </div>

          <button
            type="submit"
            class="w-full bg-royal-green-500 text-white font-semibold py-3 rounded-lg hover:bg-royal-green-600 transition-colors cursor-pointer"
          >
            Start Free Trial
          </button>

          <p class="text-xs text-center text-[var(--text-muted)]">
            By signing up, you agree to our <a href="/terms" class="text-[var(--color-link)] link-secondary">Terms of Service</a> and <a href="/privacy" class="text-[var(--color-link)] link-secondary">Privacy Policy</a>.
          </p>
          <p class="text-sm text-center text-[var(--text-tertiary)] font-medium pt-2">
            Already have an account? <a href="https://accounts.multisystems.ai/login" class="text-[var(--color-link)] link-secondary font-semibold">Log in</a>
          </p>
        </form>

        <!-- Trust indicators -->
        <div class="reveal grid grid-cols-3 gap-4 mt-10">
          <div class="text-center">
            <div class="w-10 h-10 rounded-full bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mx-auto mb-2">
              <svg class="w-5 h-5 text-[var(--color-link)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            </div>
            <p class="text-sm font-semibold text-[var(--text-secondary)]">14-day free trial</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 rounded-full bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mx-auto mb-2">
              <svg class="w-5 h-5 text-[var(--color-link)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
              </svg>
            </div>
            <p class="text-sm font-semibold text-[var(--text-secondary)]">No credit card required</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 rounded-full bg-[var(--surface-alt)] border border-[var(--border)] flex items-center justify-center mx-auto mb-2">
              <svg class="w-5 h-5 text-[var(--color-link)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
            <p class="text-sm font-semibold text-[var(--text-secondary)]">Cancel anytime</p>
          </div>
        </div>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={signupFaqs} name="signup-faq" />
  </main>
  <Footer />
</Layout>
