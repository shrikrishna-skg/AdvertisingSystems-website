---
---

<section class="relative py-32 overflow-hidden" aria-labelledby="cta-heading">
  <!-- Background effects -->
  <div class="mesh-gradient absolute inset-0"></div>
  <div class="dot-grid absolute inset-0"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>
  <div class="watermark-brand" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 id="cta-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl xl:text-[56px] font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
      Ready to make <span class="text-gradient">every ad dollar</span> count?
    </h2>
    <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
      Join thousands of businesses running smarter, more profitable campaigns.
    </p>

    <div class="reveal mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/signup"
        class="btn-cta-primary w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20"
      >
        <span class="cta-accent-line rounded-t-lg" aria-hidden="true"></span>
        <span class="relative">Start Free Trial</span>
        <svg class="w-4 h-4 relative" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a
        href="/book-demo"
        class="btn-cta-primary w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20"
      >
        <span class="cta-accent-line rounded-t-lg" aria-hidden="true"></span>
        <span class="relative">Book a Demo</span>
      </a>
    </div>

    <p class="reveal mt-6 text-sm font-medium text-[var(--text-muted)]">No credit card required &middot; 14-day free trial &middot; Cancel anytime</p>
  </div>
</section>
