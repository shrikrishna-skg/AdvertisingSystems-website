---
import { AnimatedHero } from './ui/animated-hero';
---

<section class="relative pt-28 pb-20 sm:pt-40 sm:pb-32 md:pt-48 md:pb-40 overflow-hidden" aria-labelledby="hero-heading">
  <!-- Background effects -->
  <div class="mesh-gradient absolute inset-0"></div>
  <div class="dot-grid absolute inset-0"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[min(800px,100vw)] h-[min(600px,80vh)] bg-[var(--hero-glow)] rounded-full blur-[128px]" aria-hidden="true"></div>
  <div class="watermark-brand" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
    <div class="text-center max-w-5xl mx-auto min-w-0">
      <!-- Logo -->
      <div class="reveal mb-4 flex justify-center">
        <a href="/" class="inline-block" aria-label="AdvertisingSystems home">
          <svg class="w-10 h-10 sm:w-12 sm:h-12 text-[var(--text-primary)]" viewBox="10 -1 44 58" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M26 16 A8 8 0 0 1 38 16" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" opacity="0.4"/>
            <path d="M22 11 A13 11 0 0 1 42 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.22"/>
            <line x1="32" y1="20" x2="22" y2="38" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            <line x1="32" y1="20" x2="42" y2="38" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            <line x1="22" y1="38" x2="14" y2="54" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.7"/>
            <line x1="42" y1="38" x2="50" y2="54" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.7"/>
            <line x1="22" y1="38" x2="42" y2="38" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.8"/>
            <line x1="14" y1="54" x2="50" y2="54" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.15"/>
            <circle cx="32" cy="20" r="4.2" fill="currentColor"/>
            <circle cx="22" cy="38" r="3.5" fill="currentColor" opacity="0.85"/>
            <circle cx="42" cy="38" r="3.5" fill="currentColor" opacity="0.85"/>
            <circle cx="14" cy="54" r="2.8" fill="currentColor" opacity="0.5"/>
            <circle cx="50" cy="54" r="2.8" fill="currentColor" opacity="0.5"/>
          </svg>
        </a>
      </div>
      <!-- Trust badge — Google-style subtle -->
      <div class="reveal inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 sm:px-3.5 sm:py-2 mb-6 sm:mb-8 bg-[var(--surface-alt)] border border-[var(--border-subtle)]">
        <span class="w-1.5 h-1.5 bg-[var(--text-muted)] rounded-full shrink-0"></span>
        <span class="text-[10px] sm:text-xs font-medium text-[var(--text-tertiary)]">AI-powered advertising management — by Multisystems</span>
      </div>

      <!-- Headline: rotating titles (Make money, Increase Reach, Scale Smarter, Save Time) -->
      <div class="reveal">
        <AnimatedHero
          client:load
          titles={['Make money', 'Increase Reach', 'Scale Smarter', 'Save Time']}
          prefix="Your ads should "
          suffix=""
          subheadline="The AI advertising engine that unifies Google, Meta & OTA campaigns into one system — then optimizes every dollar while you sleep."
        />
      </div>

      <!-- CTAs — Google style: one green primary, one secondary link -->
      <div class="reveal mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/signup"
          class="btn-cta-primary w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors"
        >
          <span class="cta-accent-line rounded-lg" aria-hidden="true"></span>
          <span class="relative">Start now</span>
          <svg class="w-4 h-4 relative" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="/book-demo" class="link-secondary text-base font-medium px-4 py-2">Schedule a meeting</a>
      </div>

      <!-- Trust text -->
      <p class="reveal mt-6 text-sm font-medium text-[var(--text-muted)]">No credit card required · 14-day free trial · Cancel anytime</p>
    </div>

    <!-- Hero Dashboard Mockup -->
    <div class="reveal mt-20 max-w-4xl mx-auto">
      <div class="glass rounded-2xl overflow-hidden shadow-2xl">
        <!-- Browser chrome -->
        <div class="flex items-center gap-2 px-5 py-3.5 border-b border-[var(--browser-border)] bg-[var(--browser-chrome-bg)]">
          <div class="flex gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--browser-dot)]"></span>
          </div>
          <div class="flex-1 ml-3">
            <div class="bg-[var(--browser-url-bg)] rounded-md px-3 py-1 text-xs text-[var(--browser-url-text)] max-w-xs">app.advertisingsystems.ai/dashboard</div>
          </div>
        </div>

        <!-- Dashboard content -->
        <div class="p-6 sm:p-8 bg-[var(--surface-alt)]">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
            <div class="glass rounded-xl p-4 text-center">
              <div class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)]">5.2x</div>
              <div class="text-[11px] font-semibold text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">ROAS</div>
            </div>
            <div class="glass rounded-xl p-4 text-center">
              <div class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)]">$12.4</div>
              <div class="text-[11px] font-semibold text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">CPA</div>
            </div>
            <div class="glass rounded-xl p-4 text-center">
              <div class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)]">2,847</div>
              <div class="text-[11px] font-semibold text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">Conv.</div>
            </div>
            <div class="glass rounded-xl p-4 text-center">
              <div class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)]">-38%</div>
              <div class="text-[11px] font-semibold text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">Waste</div>
            </div>
          </div>

          <div class="glass rounded-xl p-5">
            <div class="flex items-center justify-between mb-4">
              <span class="text-sm font-medium text-[var(--text-tertiary)]">Revenue by Channel</span>
              <span class="text-xs font-medium text-[var(--text-muted)]">Last 30 days</span>
            </div>
            <div class="flex items-end justify-between h-32 gap-2">
              <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 45%"></div>
              <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 62%"></div>
              <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 48%"></div>
              <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 71%"></div>
              <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 85%"></div>
              <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 67%"></div>
              <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to)]" style="height: 92%"></div>
              <div class="flex-1 rounded-t bg-gradient-to-t from-[var(--bar-fill-from)] to-[var(--bar-fill-to-strong)]" style="height: 100%"></div>
            </div>
            <div class="flex justify-between mt-3 text-[10px] font-medium text-[var(--text-muted)]">
              <span>W1</span><span>W2</span><span>W3</span><span>W4</span><span>W5</span><span>W6</span><span>W7</span><span>W8</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section-line mt-32"></div>
</section>
