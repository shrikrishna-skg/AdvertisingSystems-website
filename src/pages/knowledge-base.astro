---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { knowledgeBaseFaqs } from '../data/page-faqs';

const breadcrumbs = [{ name: 'Knowledge Base', href: '/knowledge-base' }];

const categories = [
  {
    title: 'Getting Started',
    description: 'Account setup, onboarding walkthrough, and launching your first campaign.',
    icon: 'rocket',
    articles: ['Quick start guide', 'Account setup', 'Your first campaign'],
  },
  {
    title: 'Campaign Management',
    description: 'Creating, editing, duplicating, and running bulk operations on campaigns.',
    icon: 'megaphone',
    articles: ['Create a campaign', 'Bulk editing', 'Campaign templates'],
  },
  {
    title: 'AI & Optimization',
    description: 'Automated bidding strategies, budget allocation, and audience optimization.',
    icon: 'sparkles',
    articles: ['Smart bidding', 'Budget optimizer', 'Audience insights'],
  },
  {
    title: 'Analytics & Reporting',
    description: 'Custom dashboards, scheduled exports, and multi-touch attribution.',
    icon: 'chart',
    articles: ['Dashboard builder', 'Scheduled reports', 'Attribution models'],
  },
  {
    title: 'Integrations',
    description: 'Connecting Google Ads, Meta, OTAs, and using the AdvertisingSystems API.',
    icon: 'plug',
    articles: ['Google Ads setup', 'Meta Ads setup', 'API reference'],
  },
  {
    title: 'Account & Billing',
    description: 'Subscription plans, invoices, team management, and permissions.',
    icon: 'user',
    articles: ['Manage your plan', 'Invoices & receipts', 'Team roles'],
  },
];
---

<Layout
  title="Knowledge Base — AdvertisingSystems | Guides & How-To"
  description="Step-by-step guides for setup, campaigns, AI optimization, analytics, integrations, and billing. Get the most out of AdvertisingSystems."
  breadcrumbs={breadcrumbs}
>
  <Navbar />
  <Breadcrumb items={breadcrumbs} />
  <main>
    <!-- Hero -->
    <section class="pt-36 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 mesh-gradient opacity-30"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center">
          <h1 class="reveal text-4xl sm:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
            Knowledge <span class="text-gradient">Base</span>
          </h1>
          <p class="reveal mt-5 text-lg text-[var(--text-tertiary)] max-w-2xl mx-auto leading-relaxed">
            Everything you need to get the most out of AdvertisingSystems.
          </p>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Start here / Popular -->
    <section class="py-16" aria-labelledby="start-here-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="start-here-heading" class="reveal text-xl sm:text-2xl font-bold text-[var(--text-primary)] mb-6 tracking-[-0.02em]">
          Start here
        </h2>
        <div class="reveal grid sm:grid-cols-3 gap-4">
          <a href="#" class="glass rounded-xl p-5 hover:border-royal-green-500/20 transition-colors group block">
            <span class="text-sm font-semibold text-royal-green-600">Quick start guide</span>
            <p class="text-sm text-[var(--text-tertiary)] mt-1 font-medium">Get up and running in 15 minutes</p>
          </a>
          <a href="#" class="glass rounded-xl p-5 hover:border-royal-green-500/20 transition-colors group block">
            <span class="text-sm font-semibold text-royal-green-600">Account setup</span>
            <p class="text-sm text-[var(--text-tertiary)] mt-1 font-medium">Connect your first ad account</p>
          </a>
          <a href="#" class="glass rounded-xl p-5 hover:border-royal-green-500/20 transition-colors group block">
            <span class="text-sm font-semibold text-royal-green-600">Your first campaign</span>
            <p class="text-sm text-[var(--text-tertiary)] mt-1 font-medium">Launch and optimize with AI</p>
          </a>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Categories -->
    <section class="pb-20" aria-label="Knowledge base categories">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="reveal text-xl sm:text-2xl font-bold text-[var(--text-primary)] mb-6 tracking-[-0.02em]">Browse by topic</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {categories.map((category) => (
            <a href="#" class="reveal group glass rounded-2xl p-7 hover:border-royal-green-500/20 transition-all duration-300">
              <div class="w-12 h-12 rounded-full bg-royal-green-500/10 flex items-center justify-center mb-5">
                {category.icon === 'rocket' && (
                  <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                  </svg>
                )}
                {category.icon === 'megaphone' && (
                  <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46" />
                  </svg>
                )}
                {category.icon === 'sparkles' && (
                  <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                  </svg>
                )}
                {category.icon === 'chart' && (
                  <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                  </svg>
                )}
                {category.icon === 'plug' && (
                  <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                  </svg>
                )}
                {category.icon === 'user' && (
                  <svg class="w-6 h-6 text-royal-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                  </svg>
                )}
              </div>
              <h2 class="text-lg font-bold text-[var(--text-primary)] mb-2 group-hover:text-royal-green-600 transition-colors">{category.title}</h2>
              <p class="text-sm text-[var(--text-tertiary)] leading-relaxed mb-4">{category.description}</p>
              <ul class="space-y-1.5">
                {category.articles.map((article) => (
                  <li class="flex items-center gap-2 text-sm text-[var(--text-muted)]">
                    <svg class="w-3.5 h-3.5 text-royal-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                    {article}
                  </li>
                ))}
              </ul>
            </a>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <FAQSection title="Common questions" faqs={knowledgeBaseFaqs} name="kb-faq" />

    <div class="section-line"></div>

    <!-- Can't find it? -->
    <section class="pb-28" aria-labelledby="cant-find-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="reveal glass rounded-2xl p-8 sm:p-10 text-center">
          <h2 id="cant-find-heading" class="text-2xl font-bold text-[var(--text-primary)] mb-3">Can't find your answer?</h2>
          <p class="text-[var(--text-tertiary)] font-medium mb-6 max-w-lg mx-auto">
            Check our FAQ for quick answers to common questions, or contact support and we'll get back to you within 24 hours.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/faq" class="inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold px-6 py-3 rounded-lg hover:bg-royal-green-600 transition-colors">
              View FAQ
            </a>
            <a href="/contact" class="inline-flex items-center justify-center gap-2 btn-secondary font-semibold px-6 py-3 rounded-lg">
              Contact support
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
