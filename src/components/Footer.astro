---
const footerColumns = [
  {
    title: 'Product',
    links: [
      { text: 'All Features', href: '/features' },
      { text: 'Campaign Intelligence', href: '/features/campaign-management' },
      { text: 'AI Optimization', href: '/features/ai-optimization' },
      { text: 'Performance Analytics', href: '/features/analytics' },
      { text: 'Automation Studio', href: '/features/automation' },
      { text: 'Budget Allocator', href: '/features/budget-intelligence' },
      { text: 'OTA Advertising', href: '/ota-advertising' },
    ],
  },
  {
    title: 'Comparisons',
    links: [
      { text: 'vs Manual', href: '/vs/manual' },
      { text: 'vs Google Ads Only', href: '/vs/google-ads' },
      { text: 'vs Meta Ads Only', href: '/vs/meta-ads' },
      { text: 'vs Madgicx', href: '/vs/madgicx' },
      { text: 'vs Optmyzr', href: '/vs/optmyzr' },
    ],
  },
  {
    title: 'Company',
    links: [
      { text: 'About', href: '/about' },
      { text: 'Blog', href: '/blog' },
      { text: 'Careers', href: '/careers' },
      { text: 'Contact', href: '/contact' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { text: 'FAQ', href: '/faq' },
      { text: 'Pricing', href: '/pricing' },
      { text: 'Pricing Intelligence', href: '/pricing-intelligence' },
      { text: 'Knowledge Base', href: '/knowledge-base' },
      { text: 'Case Studies', href: '/case-studies' },
      { text: 'Integrations', href: '/integrations' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { text: 'Privacy', href: '/privacy' },
      { text: 'Terms', href: '/terms' },
      { text: 'Cookies', href: '/cookies' },
      { text: 'Security', href: '/security' },
    ],
  },
];
---

<!-- Pre-footer CTA band — Google-style: clean strip, one green CTA -->
<section class="py-12 sm:py-16 lg:py-20 bg-[var(--surface-alt)] border-y border-[var(--border)]" aria-labelledby="footer-cta-heading">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center min-w-0">
    <h2 id="footer-cta-heading" class="text-xl sm:text-2xl md:text-3xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
      Ready to master your advertising?
    </h2>
    <a
      href="/book-demo"
      class="btn-cta-primary mt-8 inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors"
    >
      <span class="cta-accent-line rounded-lg" aria-hidden="true"></span>
      <span class="relative">Schedule a meeting</span>
      <svg class="w-4 h-4 relative" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</section>

<footer class="footer-block relative overflow-hidden bg-[var(--footer-bg)] border-t border-[var(--footer-border)] pt-16 pb-12 sm:pb-16 text-[var(--footer-text)]" role="contentinfo">
  <div class="watermark-brand watermark-brand-on-dark" aria-hidden="true"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
    <!-- Columns -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 sm:gap-8 lg:gap-10 mb-12 sm:mb-16 lg:mb-20">
      {footerColumns.map((column) => (
        <nav aria-label={column.title}>
          <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-4">{column.title}</h3>
          <ul class="space-y-3" role="list">
            {column.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm font-medium transition-colors">{link.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[var(--footer-border)] pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <svg class="w-8 h-8 shrink-0" viewBox="10 -1 44 58" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M26 16 A8 8 0 0 1 38 16" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" opacity="0.5"/>
          <path d="M22 11 A13 11 0 0 1 42 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.3"/>
          <line x1="32" y1="20" x2="22" y2="38" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <line x1="32" y1="20" x2="42" y2="38" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <line x1="22" y1="38" x2="14" y2="54" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.8"/>
          <line x1="42" y1="38" x2="50" y2="54" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.8"/>
          <line x1="22" y1="38" x2="42" y2="38" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" opacity="0.9"/>
          <line x1="14" y1="54" x2="50" y2="54" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.2"/>
          <circle cx="32" cy="20" r="4.2" fill="currentColor"/>
          <circle cx="22" cy="38" r="3.5" fill="currentColor" opacity="0.9"/>
          <circle cx="42" cy="38" r="3.5" fill="currentColor" opacity="0.9"/>
          <circle cx="14" cy="54" r="2.8" fill="currentColor" opacity="0.6"/>
          <circle cx="50" cy="54" r="2.8" fill="currentColor" opacity="0.6"/>
        </svg>
        <div>
          <span class="text-base font-bold footer-muted">AdvertisingSystems</span>
          <span class="text-xs font-medium footer-faint block mt-0.5">by Multisystems</span>
        </div>
      </div>

      <p class="text-sm font-medium footer-muted">&copy; 2026 Multisystems Inc. All rights reserved.</p>
    </div>
  </div>
</footer>
