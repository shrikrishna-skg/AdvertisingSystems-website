---
interface Props {
  title?: string;
  faqs: { question: string; answer: string }[];
  showContactLink?: boolean;
  name?: string;
}

const { title = 'Common questions', faqs, showContactLink = true, name = 'page-faq' } = Astro.props;
---

<section class="py-16 sm:py-20 lg:py-28" aria-labelledby="section-faq-heading">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 min-w-0">
    <h2 id="section-faq-heading" class="reveal text-center text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em] mb-12">
      {title}
    </h2>
    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="reveal group glass rounded-xl hover:border-royal-blue-500/20 transition-colors" name={name}>
          <summary class="flex items-center justify-between cursor-pointer p-5 sm:p-6 list-none [&::-webkit-details-marker]:hidden">
            <h3 class="text-base sm:text-lg font-semibold text-[var(--text-primary)] pr-4">{faq.question}</h3>
            <svg class="w-5 h-5 text-[var(--text-muted)] shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 sm:px-6 pb-5 sm:pb-6">
            <p class="text-[var(--text-tertiary)] font-medium leading-relaxed">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
    {showContactLink && (
      <div class="reveal text-center mt-12">
        <p class="text-[var(--text-muted)] font-medium">Still have questions?</p>
        <a href="/faq" class="link-secondary font-semibold">View full FAQ</a>
        <span class="text-[var(--text-muted)]"> or </span>
        <a href="/contact" class="link-secondary font-semibold">contact us</a>
      </div>
    )}
  </div>
</section>
