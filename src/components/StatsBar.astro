---
const stats = [
  { value: '$5.2B', label: 'Ad Spend Optimized' },
  { value: '4.2x', label: 'Avg ROAS Lift' },
  { value: '-38%', label: 'Lower CPA' },
  { value: '12hrs', label: 'Saved Per Week' },
];

const platforms = ['Google Ads', 'Meta Ads', 'Booking.com', 'Expedia', 'TripAdvisor', 'Airbnb'];
---

<section class="py-24" aria-label="Key metrics">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {stats.map((stat) => (
        <div class="reveal glass hover-glow rounded-2xl p-6 sm:p-8 text-center">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gradient tracking-[-0.03em]">{stat.value}</div>
          <div class="mt-3 text-[13px] text-[var(--text-muted)] uppercase tracking-[0.1em] font-semibold">{stat.label}</div>
        </div>
      ))}
    </div>

    <div class="reveal mt-16 text-center">
      <p class="text-sm font-medium text-[var(--text-muted)] mb-6">Trusted by businesses advertising on</p>
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        {platforms.map((name) => (
          <span class="text-sm font-semibold text-[var(--text-faint)]">{name}</span>
        ))}
      </div>
    </div>
  </div>
</section>
