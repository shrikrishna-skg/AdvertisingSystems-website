---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { pricingPlans } from '../data/pricing';
import {
  competitors,
  planFeatureMatrix,
  ourDifferentiators,
  pricingPageFaqs,
} from '../data/competitor-pricing';

const breadcrumbs = [{ name: 'Pricing', href: '/pricing' }];

function formatCell(value: boolean | string): string {
  if (typeof value === 'boolean') return value ? 'Yes' : '—';
  return value;
}
---

<Layout
  breadcrumbs={[{ name: 'Home', href: '/' }, ...breadcrumbs]}
  title="Pricing — AdvertisingSystems | Plans, Comparison & Competitor Analysis"
  description="Transparent pricing by ad account. Compare plans and see how AdvertisingSystems stacks up vs Madgicx, Optmyzr, and Smartly — one price, no overages."
>
  <Navbar />
  <Breadcrumb items={[{ name: 'Home', href: '/' }, ...breadcrumbs]} />
  <main>
    <!-- Hero -->
    <section class="relative pt-28 pb-16 sm:pt-40 sm:pb-20 md:pt-48 md:pb-28 overflow-hidden" aria-labelledby="pricing-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[min(600px,100vw)] h-[min(400px,60vh)] bg-[var(--hero-glow)] rounded-full blur-[128px]" aria-hidden="true"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center min-w-0">
        <div class="reveal inline-flex items-center gap-2 glass rounded-full px-4 py-2 sm:px-5 mb-6 sm:mb-8">
          <span class="w-2 h-2 bg-royal-green-400 rounded-full animate-pulse shrink-0"></span>
          <span class="text-xs sm:text-sm font-medium text-[var(--text-tertiary)]">Plans & comparison</span>
        </div>

        <h1 id="pricing-heading" class="reveal text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em] break-words">
          Simple pricing. <span class="text-gradient">No games.</span>
        </h1>
        <p class="reveal mt-6 text-xl sm:text-2xl font-medium text-[var(--text-secondary)] max-w-2xl mx-auto">
          One price per plan. No % of ad spend, no overages. See how we compare to Madgicx, Optmyzr, and Smartly.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#plans" class="inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20">
            View plans
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <a href="#compare" class="inline-flex items-center justify-center gap-2 btn-secondary font-semibold text-base px-8 py-3.5 rounded-lg">
            Compare competitors
          </a>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Competitor comparison -->
    <section id="compare" class="py-28" aria-labelledby="compare-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="compare-heading" class="reveal text-center text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          How we <span class="text-gradient">compare</span>
        </h2>
        <p class="reveal mt-4 text-center text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          AdvertisingSystems vs leading ad management tools. We focus on transparent pricing and cross-channel coverage.
        </p>

        <div class="reveal mt-16 overflow-x-auto">
          <table class="w-full min-w-[800px] border-collapse glass rounded-2xl overflow-hidden" role="table">
            <thead>
              <tr class="border-b border-[var(--border)]">
                <th class="text-left p-4 sm:p-5 font-semibold text-[var(--text-primary)] bg-royal-green-500/5">Tool</th>
                <th class="text-left p-4 sm:p-5 font-semibold text-[var(--text-primary)]">Pricing model</th>
                <th class="text-left p-4 sm:p-5 font-semibold text-[var(--text-primary)]">Starting price</th>
                <th class="text-left p-4 sm:p-5 font-semibold text-[var(--text-primary)]">Platforms</th>
                <th class="text-left p-4 sm:p-5 font-semibold text-[var(--text-primary)]">AI / cross-channel</th>
                <th class="text-left p-4 sm:p-5 font-semibold text-[var(--text-primary)]">OTA support</th>
                <th class="text-left p-4 sm:p-5 font-semibold text-[var(--text-primary)]">Overage / extra fees</th>
              </tr>
            </thead>
            <tbody>
              {competitors.map((row, i) => (
                <tr class={`border-b border-[var(--border)] last:border-b-0 ${row.name === 'AdvertisingSystems' ? 'bg-royal-green-500/5' : ''}`}>
                  <td class="p-4 sm:p-5 font-semibold text-[var(--text-primary)]">
                    {row.name === 'AdvertisingSystems' ? (
                      <span class="text-royal-green-600">AdvertisingSystems</span>
                    ) : (
                      row.name
                    )}
                  </td>
                  <td class="p-4 sm:p-5 text-sm text-[var(--text-secondary)]">{row.pricingModel}</td>
                  <td class="p-4 sm:p-5 text-sm text-[var(--text-secondary)]">{row.startingPrice}</td>
                  <td class="p-4 sm:p-5 text-sm text-[var(--text-tertiary)] max-w-[180px]">{row.platforms}</td>
                  <td class="p-4 sm:p-5 text-sm text-[var(--text-tertiary)] max-w-[160px]">{row.aiOptimization}</td>
                  <td class="p-4 sm:p-5 text-sm text-[var(--text-tertiary)]">{row.otaSupport}</td>
                  <td class="p-4 sm:p-5 text-sm text-[var(--text-tertiary)] max-w-[140px]">{row.overagesOrExtra}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="reveal mt-6 text-center text-sm font-medium text-[var(--text-muted)]">
          Competitor pricing and positioning based on public information. Last updated for current market context.
        </p>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Why we're different -->
    <section class="py-28" aria-labelledby="different-heading">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="different-heading" class="reveal text-center text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          Why our <span class="text-gradient">pricing</span> is different
        </h2>
        <p class="reveal mt-4 text-center text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          No percentage of spend. No overages. One platform for Google, Meta, and OTAs.
        </p>

        <div class="reveal mt-16 grid md:grid-cols-2 gap-6 lg:gap-8">
          {ourDifferentiators.map((item) => (
            <div class="glass rounded-2xl p-8 border-t-4 border-royal-green-500/30">
              <h3 class="text-lg font-bold text-[var(--text-primary)] mb-3">{item.title}</h3>
              <p class="text-[var(--text-tertiary)] font-medium leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Plan cards -->
    <section id="plans" class="py-28" aria-labelledby="plans-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="plans-heading" class="reveal text-center text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          Choose your <span class="text-gradient">plan</span>
        </h2>
        <p class="reveal mt-4 text-center text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          Same powerful AI and modules on every plan. Scale by ad account count.
        </p>

        <div class="reveal mt-16 grid md:grid-cols-3 gap-6 lg:gap-8 max-w-4xl mx-auto items-start">
          {pricingPlans.map((plan) => (
            <article class={`relative glass rounded-2xl p-8 transition-all duration-300 overflow-visible ${
              plan.highlighted ? 'border-royal-green-500/30 shadow-lg shadow-royal-green-500/[0.08]' : ''
            } ${plan.badge ? 'pt-10' : ''}`}>
              {plan.highlighted && (
                <span class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-royal-green-300 via-royal-green-500 to-royal-green-600 rounded-t-2xl" aria-hidden="true"></span>
              )}
              {plan.badge && (
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2">
                  <span class="bg-royal-green-500 text-white text-xs font-semibold px-3 py-1.5 rounded-full whitespace-nowrap">{plan.badge}</span>
                </div>
              )}

              <div class="text-center min-h-[4.5rem] flex flex-col justify-center">
                <h3 class="text-lg font-bold text-[var(--text-primary)]">{plan.name}</h3>
                <div class="mt-4 flex items-baseline justify-center gap-1 pb-0.5">
                  <span class={`text-4xl font-bold tracking-[-0.03em] leading-tight ${plan.highlighted ? 'text-gradient' : 'text-[var(--text-primary)]'}`}>{plan.price}</span>
                  {plan.period && <span class="text-[var(--text-muted)] text-sm font-medium">{plan.period}</span>}
                </div>
                <p class="mt-2 text-sm font-medium text-[var(--text-tertiary)]">{plan.description}</p>
              </div>

              <a
                href={plan.name === 'Enterprise' ? '/contact' : '/signup'}
                class={`mt-8 block w-full text-center text-sm font-semibold py-3 rounded-lg transition-colors ${
                  plan.highlighted
                    ? 'bg-royal-green-500 text-white hover:bg-royal-green-600'
                    : 'btn-secondary'
                }`}
              >
                {plan.cta.text}
              </a>
            </article>
          ))}
        </div>

        <p class="reveal text-center mt-10 text-sm font-medium text-[var(--text-muted)]">
          All plans include unlimited campaigns, AI optimization, real-time analytics, and 14-day free trial.
        </p>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Feature matrix -->
    <section class="py-28" aria-labelledby="features-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="features-heading" class="reveal text-center text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          What's in each <span class="text-gradient">plan</span>
        </h2>
        <p class="reveal mt-4 text-center text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          Full feature breakdown. No hidden paywalls inside your tier.
        </p>

        <div class="reveal mt-16 overflow-x-auto">
          <table class="w-full min-w-[640px] border-collapse glass rounded-2xl overflow-hidden" role="table">
            <thead>
              <tr class="border-b border-[var(--border)]">
                <th class="text-left p-4 sm:p-5 font-semibold text-[var(--text-primary)]">Feature</th>
                <th class="text-center p-4 sm:p-5 font-semibold text-[var(--text-primary)]">Starter</th>
                <th class="text-center p-4 sm:p-5 font-semibold text-[var(--text-primary)] bg-royal-green-500/5">Professional</th>
                <th class="text-center p-4 sm:p-5 font-semibold text-[var(--text-primary)]">Enterprise</th>
              </tr>
            </thead>
            <tbody>
              {planFeatureMatrix.map((row, i) => (
                <tr class={`border-b border-[var(--border)] last:border-b-0 ${i % 2 === 1 ? 'bg-[var(--surface-alt)]/50' : ''}`}>
                  <td class="p-4 sm:p-5 text-sm font-medium text-[var(--text-secondary)]">{row.feature}</td>
                  <td class="p-4 sm:p-5 text-center text-sm text-[var(--text-tertiary)]">{formatCell(row.starter)}</td>
                  <td class="p-4 sm:p-5 text-center text-sm text-[var(--text-tertiary)] bg-royal-green-500/5">
                    {formatCell(row.professional)}
                  </td>
                  <td class="p-4 sm:p-5 text-center text-sm text-[var(--text-tertiary)]">{formatCell(row.enterprise)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- ROI / trust -->
    <section class="py-28" aria-labelledby="roi-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="roi-heading" class="reveal text-3xl sm:text-4xl font-bold text-[var(--text-primary)] tracking-[-0.03em]">
          One platform. One price. <span class="text-gradient">Predictable.</span>
        </h2>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] leading-relaxed">
          On average, customers see 4.2x ROAS improvement and 38% lower CPA in the first 90 days. Your subscription pays for itself when the AI finds the inefficiencies you've been missing.
        </p>
        <p class="reveal mt-4 text-sm font-medium text-[var(--text-muted)]">
          Powering $5.2B+ in ad spend across 2,000+ businesses — by Multisystems.
        </p>
        <ul class="reveal mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-[var(--text-secondary)] font-medium" role="list">
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-royal-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            14-day free trial
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-royal-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            No credit card required
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-royal-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Cancel anytime
          </li>
        </ul>
      </div>
    </section>

    <div class="section-line"></div>

    <!-- FAQ -->
    <section class="py-28" aria-labelledby="faq-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <FAQSection
          title="Pricing questions"
          faqs={pricingPageFaqs}
          name="pricing-page-faq"
          showContactLink={true}
        />
      </div>
    </section>

    <div class="section-line"></div>

    <!-- Final CTA -->
    <section class="relative py-32 overflow-hidden" aria-labelledby="final-cta-heading">
      <div class="mesh-gradient absolute inset-0"></div>
      <div class="dot-grid absolute inset-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[var(--hero-glow)] rounded-full blur-[128px]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 id="final-cta-heading" class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight tracking-[-0.03em]">
          Ready for <span class="text-gradient">predictable pricing?</span>
        </h2>
        <p class="reveal mt-6 text-lg font-medium text-[var(--text-tertiary)] max-w-2xl mx-auto">
          Start a free trial or book a demo. No hidden fees — ever.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/signup" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-royal-green-500 text-white font-semibold text-base px-8 py-3.5 rounded-lg hover:bg-royal-green-600 transition-colors shadow-lg shadow-royal-green-500/20">
            Start free trial
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/book-demo" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 btn-secondary font-semibold text-base px-8 py-3.5 rounded-lg">
            Book a demo
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
